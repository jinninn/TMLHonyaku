Vanilla: {
	Armor: {
		SetBonus: {
			Adamantite: {
				$parentVal:
					'''
					現在のダメージ軽減率の半分がクリティカル率に加算される
					連続してダメージを与え続けると、防御力が徐々に上昇し、最大で{0}まで増加する
					ダメージを与えないと、このボーナスは徐々に減少する
					この追加された防御力は、アーマーブレイクによって打ち消される
					'''
				Melee: 近接速度が15%増加し、移動速度が20%増加
			}

			Cobalt: {
				$parentVal:
					'''
					最大速度と加速度が{0}%増加する
					現在の移動速度に応じてダメージとクリティカル率が上昇し、最大で{0}%になる
					'''
				Melee: 近接ダメージが10%増加
			}

			Copper: すべてのダメージが2増加
			Crimson:
				'''
				ライフ自然回復が大幅に増進
				ダメージを受けない時間が長いほどライフ自然回復がさらに増進
				静止するとライフ自然回復が大幅に増進
				'''
			Eskimo:
				'''
				すべての冷気系デバフダメージが1.25倍に増加
				冷気を持つ敵から受ける接触ダメージが減少する
				凍え、凍結、凍傷に対する耐性を付与
				'''
			Rain:
				'''
				ジャンプ速度が24%上昇し、オートジャンプが可能になる
				ジャンプ時に水しぶきを発生させ、敵にダメージを与えノックバックさせる
				雨天時はこの水しぶきが強化される
				'''
			Forbidden:
				'''
				セットボーナス：{0}でカーソル位置に古代の嵐を呼び出す
				魔法武器装備中でもミニオンのダメージが低下しなくなる
				'''
			Frost:
				'''
				近接および遠距離攻撃が凍傷を付与
				{0}%のダメージ増加、対象が遠いほど効果が増加する
				近距離では近接ダメージ、遠距離では遠距離ダメージ
				'''
			Gladiator:
				'''
				+3防御力
				最大ステルス+60
