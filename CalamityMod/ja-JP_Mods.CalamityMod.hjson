				TooltipGFB: 「...ドニマイトのかけらを通して」
			}
		}

		Melee: {
			VanishingPoint: {
				DisplayName: ヴァニシング・ポイント
				Tooltip: "[GFB]"
				TooltipNormal:
					'''
					進行中に何度も分裂する槍状のビームを放つ
					「宇宙を引き裂け！」
					'''
				TooltipGFB:
					'''
					分裂しまくるランスビームを放つ....常識外れなほど大量に！
					「弾数上限を引き裂け！」
					'''
			}

			GrandDad: {
				DisplayName: 祖父の大剣
				Tooltip: "[GFB]"
				TooltipNormal:
					'''
					途方もない重量で敵をなぎ払う巨大な剣
					攻撃命中時にライフを回復する
					弱い敵に当てると凄まじい勢いで吹き飛ばす
					吹き飛ばされた敵は壁や地面に衝突すると甚大なダメージを受ける
					振っている最中に<right>を押し続けると、刃のダメージを大きく下げる代わりに吹き飛ばしダメージと速度が大幅に増加する
					[c/00B8DF:「星の半分の質量を持つ物をどうやって扱っているんだ？」]
					'''
				TooltipGFB:
					'''
					高品質な刃で敵をなぎ払う
					弱い敵に当てると凄まじい勢いで吹き飛ばし、しばしばブロック内部にめり込ませる
					吹き飛ばされた敵は壁や地面に叩きつけられるとジャム状になる
					振っている最中に<right>を押し続けると、刃のダメージを大きく下げる代わりに吹き飛ばしダメージと速度が増加、いいだろう >:]
					[c/00B8DF:「武器の説明を読め」]
					'''
			}

			BurningRevelation: {
				DisplayName: 炎の啓示
				Tooltip:
					'''
					射程: {0}ブロック
					速度: {1}
					投擲持続時間: 無限
					常に燃え続け、力を蓄え続けるヨーヨー
					直接命中でチャージが大きく増加し、チャージ量に応じた冒涜のエネルギーを放出する
					最大チャージ時、飛距離に応じてダメージが増加する追尾する星を一斉に放つ
					最大ダメージに達した星は命中時に追加爆発を起こす
					「燃え盛るそれを胸に抱く、魂は明晰さと使命で満たされる」
					'''
			}

			CrescentMoon: {
				DisplayName: クレセントムーン
				Tooltip:
					'''
					軌道の頂点で追尾する月の魔法を放つルナフレイルを投げる
					<left>長押しでフレイルを周囲に回転させ、スターバーストを生成する
					スターバーストが20ある状態で投擲後に再度<left>を長押しすると爆発を起こす
					この爆発は月の魔法の代わりにスコルピウスを召喚し、莫大なダメージと[cbuff:CalamityMod/Voidfrost]を与える
					「狂気は天才から生まれる」
					'''
			}

			GrandGuardian: {
				DisplayName: グランドガーディアン
				Tooltip:
					'''
					敵を容易に切り裂く華麗な翼付きの刃
					命中時に爆発を起こし、ライフを少し回復する
					'''
			}

			GildedProboscis: {
				DisplayName: 金装の槍
				Tooltip:
					'''
					与えたダメージに比例してライフを吸収する
					<left>で突き攻撃をチャージする
					突きは長く溜めるほど強力になる
					<right>で強力な斬り上げとともに前方へダッシュする
					ダッシュ距離は移動方向によって変化する
					常にクリティカルヒットする
					'''
			}

			GalileoGladius: {
				DisplayName: ガレリオのグラディウス
				Tooltip:
					'''
					前方を高速で連続突きし、命中時にスターバーストを生成する
					<right>で星座の鎖につないだグラディウスを投げ、敵を串刺しにして[cbuff:CalamityMod/Voidfrost]を付与する
					刃が刺さっている間に<left>または<right>で引き抜く
					<left>でスターバーストを10消費し、刃を引き抜き高ダメージを与える
					<right>で自分を刃へ引き寄せ、敵を踏み台にして跳躍できる
					跳躍時はスターバーストを20消費し、一定時間無敵になる
					「Figaro, magnifico」
					'''
			}

			BladecrestOathsword: {
				DisplayName: 刃紋の誓剣
				Tooltip:
					'''
					鋭い刃を投げ、敵を串刺しにして速度を低下させる
					1体の敵に同時に最大3本まで刺すことができる
					4回目以降の命中で、以前に刺さっていた刃を射出する
					'''
				HoldShiftTooltip:
					'''
					[c/df0049:「悪魔が生贄の儀式に用いる儀式用の刃]
					[c/df0049:　血で穢れるほど、その切れ味は増す」]
					'''
			}

			ForbiddenOathblade: {
				DisplayName: 禁断の誓剣
				Tooltip:
					'''
					鋭い刃を投げ、敵を串刺しにして燃焼と速度低下を与える
					最大3本まで刺さり、さらに命中させると以前の刃を射出する
					<right>で構えに入り、<left>で強力な斬撃を放つ
					強力な斬撃は使用後にクールダウンが必要
					串刺し状態の敵に強力な斬撃を当てると、すべての刃を射出し再度斬撃を使用可能にする
					'''
				HoldShiftTooltip:
					'''
					[c/b63cd1:「魔王に授けられた剣を模して鍛えられた刃]
					[c/b63cd1:　その称号はすべての悪魔に望まれ、同時に存在できるのは一人のみ]
					[c/b63cd1:　玉座を狙う者の目的はただ一つ、先代魔王の首」]
					'''
			}

			EntropicClaymore: {
				DisplayName: 破滅のクレイモア
				Tooltip:
					'''
					攻撃時にプラズマを扇状に放つ
					プラズマはカーソルまたは近くの敵を追尾し、より近い方を優先する
					貫通するが、最初の敵に当たると追尾をやめる
					'''
			}

			DevilsSunrise: {
				DisplayName: デビルズサンライズ
				Tooltip:
					'''
					連続斬撃を繰り出す
					時間経過で刃に地獄のエネルギーが溜まり、敵に当てると加速する
					エネルギー最大時に攻撃しながら<right>で、回転する刃をカーソルへ投げる
					回転する刃は最初に触れた敵に突き刺さり、連続で切り刻みライフを吸収する
					「ビビってるのか？」
					'''
			}

			DevilsDevastation: {
				DisplayName: 破滅の剣
				Tooltip:
					'''
					悪魔の刃を投げ、敵を串刺しにして焼き尽くし速度を低下させる
					最大5本まで刺さり、さらに命中させると以前の刃を射出する
					<right>で構えに入り、<left>で巨大な斬撃を放つ
					構え中はライフ自然回復と飛行時間回復を増進し、ダッシュのクールダウンが短縮される
					巨大な斬撃は使用後にクールダウンが必要
					串刺し状態の敵に巨大な斬撃を当てると、すべての刃を射出し再度斬撃を使用可能にする
					最後に巨大な斬撃を受けた敵にはデスマークが付与される
					構えを解除するとデスマークが爆発し、莫大なダメージを与える
					'''
				HoldShiftTooltip:
					'''
					[c/d13ca2:「煉獄の力を直接宿す地底世界の究極の刃]
					[c/d13ca2:　人間はこの力をハボックと呼ぶ、炎による秩序の不可避な崩壊]
					[c/d13ca2:　それこそがブリムストーンエレメンタルが姉妹を凌駕した理由かもしれない」]
					'''
			}

			ExaltedOathblade: {
				DisplayName: 崇高なる誓剣
				Tooltip:
					'''
					歪んだ刃を投げ、敵を串刺しにして焼き尽くし、速度を低下させる
					最大4本まで刺さり、さらに命中させると以前の刃を射出する
					<right>で構えに入り、<left>で壊滅的な斬撃を放つ
					構え中はライフ自然回復と飛行時間回復を増進し、ダッシュのクールダウンが短縮される
					壊滅的な斬撃は使用後にクールダウンが必要
					串刺し状態の敵に壊滅的な斬撃を当てると、すべての刃を射出し再度斬撃を使用可能にする
					'''
				HoldShiftTooltip:
					'''
					[c/b63cd1:「最後の魔王の伝説を元に作られた剣]
					[c/b63cd1:　圧倒的な力で戴冠し、その剣は悪魔の血と地獄の炎に染まった]
					[c/b63cd1:　彼の死後も、玉座に座る者はいない]
					[c/b63cd1:　悪魔たちはそれ以来、統一を失っている」]
					'''
