	Weapons: {
		DraedonsArsenal: {
			AerialTracker: {
				DisplayName: P-LSR: エアリアルトラッカー
				Tooltip:
					'''
					近くの敵にレーザーを放つ飛行ディスクを放つ
					レーザーは直接ダメージを与えず、代わりにスタックするレーザー焼却効果を付与する
					十分な数のレーザーが命中するか一定時間が経過すると、レーザー焼却が直接ダメージを与える
					ディスクはプレイヤーの元へ戻る際に加速する
					ステルス攻撃では2枚のディスクを投げ、より遠距離から複数の異なる対象を攻撃できる
					'''
			}

			AqueousHunterDrone: {
				DisplayName: P-PMA: 水中探査ドローン
				Tooltip:
					'''
					追尾式プラズマミサイルを連射するエビ型ドローンを召喚する
					任意の召喚武器を所持中に<right>で、ドローンに垂直ミサイルの一斉発射を命令する
					垂直ミサイルはカーソルへ向かって飛び、地面に着弾すると残留爆風を発生させる
					ドローン1体につきミニオンスロットを4使用する
					[c/1FFBFF:「神々の信奉者を追うにあたり、ヤリムはいかなる可能性も見逃すべきではないと考えていた]
					[c/1FFBFF:　水中戦を想定した兵装に異様なまでの重点が置かれたが、いずれのモデルも実戦配備されることはなかった」]
					'''
			}

			Auger: {
				DisplayName: P-GSS: オーガー
				Tooltip:
					'''
					磁気エネルギーブレードを放出する手首装着型デバイス
					<right>でカーソル位置に短時間磁力を発生させ、次の斬撃を強化する
					[c/1FFBFF:「当初は原材料を切削し、輸送用に分割するために製造された]
					[c/1FFBFF:　両手を自由に保ちながら出力を損なわない設計は、卓越した操作性を実現した」]
					'''
			}

			CountermeasureMitt: {
				DisplayName: B-LSR: 多用途グローブ
				Tooltip:
					'''
					各指先にレーザーエミッターを備えた精密溶接グローブ
					<right>で全エミッターを掌に集中させ、必ずクリティカルヒットする短距離パームブラストを放つ
					パームブラストにはクールダウンがあり、外した場合は大幅に短縮される
					[c/1FFBFF:「多くの部隊は攻撃を広範囲に分散させるか、単一目標に集中させるかを好む]
					[c/1FFBFF:　このグローブはその両方に応えるが、戦術の隔たりを埋めることはない」]
					'''
			}

			HolofibreImmolator: {
				DisplayName: R-PMA: ホロファイバー焼却装置
				Tooltip:
					'''
					重力の影響を受け、敵を貫通するプラズマ弾を3発放つ
					<left>長押しで素早くチャージし、高速プラズマアローを放つ
					プラズマアローは着弾後に爆発し、ブロックに刺さった場合はより強力な爆発を起こす
					<right>長押しで非チャージショットを連射する
					<right>と<left>を同時に長押しすると、やや遅い速度で自動的にチャージアローを放つ
					[c/1FFBFF:「ホロファイバーの優雅さは他に比類がない]
					[c/1FFBFF:　しかし、機械的な張力の方がより安定した結果を生んだかもしれない」]
					'''
			}

			Nidhogg: {
				DisplayName: B-GSS: ニーズヘッグ
				Tooltip:
					'''
					磁力駆動のエネルギーレールガンで高速連射し、命中時に弱い敵を引き寄せる持続型磁気収縮を発生させる
					磁気収縮は同時に1つまでしか存在できない
					<right>で壊滅的なエネルギービームのチャージを開始し、完了すると必ずクリティカルヒットで発射される
					このチャージ攻撃は開始後に中断できず、長いクールダウンがある
					[c/1FFBFF:「多くの兵士は磁力の破壊力を過小評価している]
					[c/1FFBFF:　このレールガンは、その圧倒的効率を疑う者を確実に引き寄せてきた」]
					'''
			}

			PhalanxSurge: {
				DisplayName: W-LSR: ファランクスサージ
				Tooltip:
					'''
					レーザーを拡散発射する
					<right>長押しで武器をチャージし、前方へ突き出して敵をエネルギースピアで串刺しにする
					チャージ攻撃発射中に<left>を長押しすると高速で前方へ突進し、追加ダメージを与える
					チャージ攻撃には短いクールダウンがある
					[c/1FFBFF:「ヤリム軍からは近接兵装を求める声が多く上がっていた]
					[c/1FFBFF:　敵を串刺しにするレーザーランスは、雷鳴のような喝采で迎えられた」]
					'''
			}

			PulseGrenade: {
				DisplayName: R-PLS: パルスグレネード
				Tooltip:
					'''
					自動再生するグレネードで、敵を追尾して8つのパルスオーブに分裂する
					パルスオーブはプレイヤーの元へ戻りながら経路上の敵に命中し、グレネードを再形成する
					ステルス攻撃では高速で投擲し、2倍のオーブに分裂する
					'''
			}

			ShortCircuit: {
				DisplayName: P-TSL: ショートサーキット
				Tooltip:
					'''
					<left>で高ノックバックのスタンボルトを高速連射する
					<right>でフックを発射し、敵に取り付いて急速に感電させる
					十分に感電させると、フックは衝撃爆発を起こしてから戻ってくる
					フック攻撃が成功すると短いクールダウンが発生するが、敵を倒した場合は適用されない
					敵の防御力を{0}無視する
					'''
			}

			Vulcan: {
				DisplayName: R-GSS: ヴァルカン
				Tooltip:
					'''
					マナを使用するガトリング砲で、左クリックでバースト射撃を行う
					<right>で磁気ハープーンを発射し、弾を引き寄せる
					ハープーンを発射するとバースト射撃モードの持続時間が延びる
					ハープーンの効果終了時、磁化された弾が高ダメージで近くの敵へ一斉に飛ぶ
					[c/1FFBFF:「元は天井設置型の採掘ビームであり、バッテリーを外しても重量はわずかしか軽減されなかった]
					[c/1FFBFF:　戦闘魔導士部隊からは不評で、ほとんど使われることはなかった」]
					'''
			}

			GalvanizingGlaive: {
				DisplayName: 亜鉛メッキのグレイブ
				Tooltip:
					'''
					攻撃が当たった敵をエネルギーフィールドで包み込む
					エネルギーフィールドが消滅すると槍は余分なエネルギーを放電する
					[c/1FFBFF:「一つの物体を素早くきれいに二つに切断する道具]
					[c/1FFBFF:　武器としての効率と信頼性は疑いようがない」]
					'''
			}

			HydraulicVoltCrasher: {
				DisplayName: 油圧ボルトクラッシャー
				Tooltip:
					'''
					電気を帯びたジャックハンマーで、命中すると近くにいるすべての敵に衝撃を与える
					[c/1FFBFF:「金属板に電気で刻印するために作られた装置]
					[c/1FFBFF:　もちろん、それは破壊的な武器としても機能する」]
					'''
			}

			MountedScanner: {
				DisplayName: マウントスキャナー
				Tooltip: 近くの敵にレーザーを発射する強力なスキャナーモジュールを頭上に召喚する
			}

			Phaseslayer: {
				DisplayName: フェーススレイヤー
				Tooltip:
					'''
					巨大なレーザーブレードを投射する
					刃はカーソルに連動して動く
					速く攻撃するほどダメージが大きくなり、追加のソードビームを放つ
					エネルギー残量が少ない時は、ブレードが小さくなる
					'''
			}

			PlasmaCaster: {
				DisplayName: プラズマキャスター
				Tooltip:
					'''
					<left>で、爆発する大きなプラズマボルトを発射する
					<right> だと、連射速度は上がるが精度は落ちる
					'''
			}

			PlasmaGrenade: {
				DisplayName: プラズマグレネード
				Tooltip:
					'''
					衝突するとプラズマに爆発する手榴弾を投げる
					ステルス攻撃は衝突時に激しく爆発し、蒸発する
					[c/1FFBFF:※グレネードには、凝縮・加熱されたプラズマが含まれています。使用には十分注意してください。]
					'''
			}

			PoleWarper: {
				DisplayName: ポールワーパー
				Tooltip:
					'''
					敵に容赦なく群がる一対の磁石を召喚する
					「互いに反発し合い、敵を引き裂くマグネットデバイス」
					'''
			}

			PulseDragon: {
				DisplayName: パルスドラゴン
				Tooltip:
					'''
					ダメージを与える電界を放つ2つのメカニカルな竜の頭を投げる
					[c/1FFBFF:「ヤリムはこの武器を製作するにあたって、昔のドラゴンをモデルにするよう特別に要求した]
					[c/1FFBFF:　くだらないな...」]
					'''
			}

			PulsePistol: {
				DisplayName: P-PLS: パルスピストル
				Tooltip: 
					'''
					近くの敵を追尾するパルスオーブを発射する
					敵に命中するとパルスオーブは2つに分裂する
					敵を倒すとパルスオーブの貫通数が増加する
					'''
			}

			PulseRifle: {
				DisplayName: A-PLS: パルスライフル
				Tooltip:
					'''
					敵にヒットすると、4つの高周波パルスに変化する
					パルスは近くのターゲットを追尾し、ヒット数に応じて追尾速度が上がる
					敵を倒した時や与ダメージが低かった場合、パルスの貫通力は減少しない
					[c/1FFBFF:「失敗作を抹殺するための、私専用の武器だ]
					[c/1FFBFF:　オリジナルが破壊された場合に備えて、設計図はバックアップしてある」]
					'''
			}

			PulseTurretRemote: {
				DisplayName: 遠隔パルスタレット
				Tooltip:
					'''
					エネルギーブラストで近くの敵を殲滅するパルスタレットを召喚する
					パルスタレットは一度に1つしか存在できない
					'''
			}

			SnakeEyes: {
				DisplayName: スネークアイ
				Tooltip:
					'''
					エネルギーボルトを発射する浮遊ドローンを召喚する
					ボルトが命中すると、ドローンはテレポートしてボルトを反射する
					反射されたボルトは、何かにぶつかると爆発する
					[c/1FFBFF:「高性能のセンサーを装備したとしても、これを回避できる者はほとんどいない。そして、これら監視の目から逃れられるものはさらに少ない]
					[c/1FFBFF:　視覚に基づく魂の力を利用した機械の実験と、私の最新のプロジェクトをつないでいる」]
					'''
			}

			SystemBane: {
				DisplayName: システムベーン
				Tooltip:
					'''
					ブロックに張り付き、近くの敵に雷を落とす不安定な装置を投げる
					ステルス攻撃は、装置に大きなダメージを与える電磁場を放出させる
					'''
			}

			TeslaCannon: {
				DisplayName: テスラキャノン
				Tooltip:
					'''
					軽量のエネルギーキャノンで、強力な電気ビームを発射し、爆発させる
					ビームは近くのターゲットに連鎖する
					'''
			}

			TheAnomalysNanogun: {
				DisplayName: 異常なナノガン
				Tooltip:
					'''
					<left>を押すと5本の速射プラズマビームが発射される
					<right>を押すと核分裂爆弾を3発発射する
					「パーティーへようこそ、相棒」
					'''
			}

			WavePounder: {
				DisplayName: ウェーブパウンダー
				Tooltip:
					'''
					爆弾を投げ、爆発する
					ステルス攻撃はとんでもなく強力な爆発を起こす
					'''
			}
		}

		Magic: {
			Nucleosynthesis: {
				DisplayName: ニュークリオシンサシス
				Tooltip:
					'''
					プレイヤーの周囲に4本のビームを放つ
					ソーラービームは敵に命中すると爆発する
					ネビュラビームは時間経過でゆるやかに掃射する
					ボルテックスビームは高速の稲妻のような魔法で、命中時に敵を感電させる
					スターダストビームは命中時に敵を追尾する小さな星を放つ
					'''
			}

			UnstableCastersGauntlet: {
				DisplayName: 不安定な術者の籠手
				Tooltip:
					'''
					<left>で貫通する針を発射
					<right>で原初の元素を象徴する紋章の輪を召喚
					紋章がある状態で<left>を押し続けると、ランダムな紋章を消費し、それぞれが攻撃を放つ
					元素の輪が展開中に再度<right>を押すと、空きスロットをすべて[c/DD84E8:歪曲]の紋章に置き換える
					[c/DD84E8:歪曲]の紋章は自動で不正確な紫の弾幕を放つ
					すべての行動には十分な[c/EADAF5:ヴィス]が必要
					[c/EADAF5:ヴィス]は時間経過で回復する
					'''
				HoldShiftTooltip:
					'''
					[c/DBD7CA:オルド]の紋章は必ずクリティカルヒットし、無限に貫通
					[c/ABB6D4:ペルディト]の紋章は敵の防御力を25無視
					[c/E89B8E:イグニス]の紋章はデイブレイクを付与
					[c/8ECBE8:アクア]の紋章は圧潰を付与
					[c/E1E88E:アエル]の紋章は大きなノックバックを持つ
					[c/ACCF9F:テラ]の紋章は鋭い岩片に分裂
					'''
			}

			Rancor: {
				DisplayName: 怨嗟の書
				Tooltip:
					'''
					魔法陣を展開し、エネルギーを蓄積した後、制御された邪悪な魔法を放つ
					魔法が触れた地面には腕と灼熱の溶岩が出現する
					'''
				Calamitas:
					'''
					ヤリムは言った。ブリムストーンエレメンタルをアザフレへ解き放ったのはオトニロウだと。
					あの頃の私は、全ての不幸を押し付ける相手を求める子供だった。だからその言葉を疑いもしなかった。
					そして私は、奴らに相応しいと思い込んだ怒りと軽蔑を、すべて叩きつけた。
					......真実に気づいたのは、すべてが手遅れになってからだった。
					'''
			}

			HyperdeathRiftScepter: {
				DisplayName: 極滅の杖
				Tooltip: 空間を引き裂く
			}

			AlphaDraconis: {
				DisplayName: 始竜の杖
				Tooltip:
					'''
					カーソル地点に向かって隕石の雨を降らせる
					攻撃が命中すると、時々スターバーストが発生し、拾うことができる
					スターバーストが十分ある状態で<right>を押すと、竜を召喚する
					竜は時間経過でスターバーストを消費し、<right>で解除できる
					竜の攻撃は[cbuff:CalamityMod/Voidfrost]を付与する
					「狂気の模倣」
					'''
			}

			AnahitasArpeggio: {
				DisplayName: アナヒタのアルペジオ
				Tooltip: "[GFB]"
				TooltipNormal:
					'''
					<left>を押し続けると、最大6つのト音記号がプレイヤーの周囲を回る
					<left>を離すと、ト音記号がカーソル地点に集まる
					集まった後、ト音記号はカーソルを追尾する
					'''
				TooltipGFB:
					'''
					「やめて！ 私の言うことを聞きなさい！！」
					7つのト音記号の魂：
					'''
			}

			Apathanull: {
				DisplayName: アパサナール
				Tooltip:
					'''
					闇の触手を放ち、敵を串刺しにする
					触手はカーソルを狙い、3回攻撃した後に消える
					'''
			}

			AuguroftheVoid: {
				DisplayName: 虚空の予兆書
				Tooltip: 属性を帯びた触手の奔流を放ち、敵を貫く
			}

			DeathValleyDuster: {
				DisplayName: 死谷の書
				Tooltip:
					'''
					敵や地形を貫通する魔法の砂の衝撃波を放つ
