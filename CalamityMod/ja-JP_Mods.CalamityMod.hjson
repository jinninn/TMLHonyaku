				'''
		}

		TheAmalgam: {
			DisplayName: アマルガム
			Tooltip:
				'''
				すべての攻撃が複数のデバフを付与し、属性デバフダメージが300%増加する
				ほとんどのバフの持続時間が2倍になり、死亡後も持続する
