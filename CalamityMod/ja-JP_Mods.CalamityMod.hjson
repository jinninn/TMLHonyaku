		Rogue: {
			Pumpkaboom: {
				DisplayName: 爆裂かぼちゃ
				Tooltip:
					'''
					敵に張り付き、遅れて爆発するかぼちゃを投げる
					ステルス攻撃ではより大きなかぼちゃを投げ、爆発前に敵を引き寄せて大爆発を起こす
					'''
			}

			AntlionSkewer: {
				DisplayName: 串刺しのアントリオン
				Tooltip:
					'''
					生きたアントリオンを串刺しにして投げ、砂の弾を放たせる
					ステルス攻撃では大量の砂玉と突風を放出
					砂雲は一時的に敵の接触ダメージを低下させる
					'''
			}

			SporeKnife: {
				DisplayName: 胞子の短剣
				Tooltip:
					'''
					巨大化した短剣を投げ、毒の胞子の雲を発生させる
					ステルス攻撃では敵に張り付き噛みつく追尾する芽が噴出する
					'''
			}

			ContaminatedBile: {
				DisplayName: 汚染された胆汁入りの瓶
				Tooltip:
					'''
					放射化した胆汁の瓶を投げ、割れたあと有毒な雲がしばらく残る
					ステルス攻撃では雲から硫黄の泡が素早く噴き上がる
					'''
			}

			Exorcism: {
				DisplayName: エクソシズム
				Tooltip:
					'''
					巨大な聖なる十字架を天へ投げ、少し後にカーソル位置へ落下させる
					落下中に当たった敵は串刺しにされ、聖なる光で繰り返し焼かれる
					効果終了時、十字形の爆発が発生する
					ステルス攻撃では十字架を回転させて投げ、カーソル位置でより強力な爆発を起こす
					'''
			}

			DoomsdayDevice: {
				DisplayName: 終末装置
				Tooltip:
					'''
					武器を直接命中させるとステルスを獲得する
					非ステルス攻撃は、フルチャージ時でもステルスを消費しない
					ステルス攻撃を限界以上に溜め続けると、ステルスが急速に減少する
					ステルス攻撃は複数の敵の間を跳ね返り、最後に強力な一撃を与える
					「壊滅的な威力を持つハイテク爆弾....起動方法は不明....
					　まあ、思いきり投げつけることはできる！」
					'''
			}

			BlazingStar: {
				DisplayName: 灼熱の手裏剣
				Tooltip:
					'''
					赤熱した跳ね返る手裏剣を投げる
					ブロックに跳ね返った後、同じ敵に再度命中できる
					ステルス攻撃は最初に当たった敵を切り裂き、高ノックバックの手裏剣を複数発生させる
					'''
			}

			Equanimity: {
				DisplayName: イクアニミティ
				Tooltip:
					'''
					敵の間を跳ね回るブーメランを投げる
					敵に当たるたびに、追尾する光の破片と貫通する闇の破片を交互に発生させる
					ステルス攻撃では跳ね返るたびに光または闇の爆発を交互に起こし、反対属性の破片を強化する
					'''
			}

			LeviathanTeeth: {
				DisplayName: リヴァイアサンの牙
				Tooltip:
					'''
					敵に突き刺さる牙を素早く扇状に投げる
					刺さった牙は敵の体をえぐり、反対側へ突き抜ける
					ステルス攻撃では巨大な牙の顎を生み出し、敵を噛み砕く
					'''
			}

			MeteorFist: {
				DisplayName: メテオフィスト
				Tooltip:
					'''
					カーソルを追尾し、時間経過で加速するワイヤー誘導式ロケットフィストを放つ
					ステルス攻撃は即座に加速を開始し、命中した敵に隕石を落とす
					'''
			}

			MoltenAmputator: {
				DisplayName: 冒涜された鎌
				Tooltip:
					'''
					回転する鎌を投げ、カーソル位置にとどまらせる
					<right>で存在するすべての鎌を呼び戻す
					敵に当たっている鎌を回収すると、その敵に大ダメージを与える
					十分なステルスがある状態で<right>を押すと自身を強化し、短時間攻撃速度を大幅に向上させる
					強化中に投げた鎌は回収できない
					'''
			}

			TheOldReaper: {
				DisplayName: 古き死神の鎌
				Tooltip:
					'''
					汚染された鎌を投げ、敵を切り裂きながら貫通する
					命中時に不安定な同位体を付与し、崩壊時に遅れて核爆発を引き起こす
					ステルス攻撃は空に鎌を投げ、数秒後に敵へ降り注ぎ、
					命中した場合は敵に向かって酸性雨を降らせる
					'''
			}

			RefractionRotor: {
				DisplayName: リフラクション・ローター
				Tooltip:
					'''
					巨大な虹色の手裏剣を投げる
					命中後しばらくして砕け、追尾する刃に分裂する
					ステルス攻撃では3枚の手裏剣を投げ、素早く敵を追尾する
					'''
			}

			ShardofAntumbra: {
				DisplayName: 本影のグレイヴ
				Tooltip:
					'''
					敵やブロックに突き刺さる宇宙の槍を投げ、敵に命中すると近くに小さな裂け目を生成する
					命中後はエネルギーを溜め、裂け目へ瞬間移動して最も近い敵を狙う
					ステルス攻撃では多数の裂け目を生み出し、転移時に追加の槍を出現させる
					'''
			}

			StarofDestruction: {
				DisplayName: スター・オブ・デストラクション
				Tooltip:
					'''
					宇宙の魔法を扇状に放ち、融合して破壊の星となる
					星は時間切れか敵に当たるまで、ゆっくりとカーソルを追尾する
					時間切れになると巨大爆発を起こし、増加したダメージを与える
					ステルス攻撃では追加の魔法を放ち、より高速で貫通する星となり、命中ごとに爆発する
					'''
			}

			ToxicantTwister: {
				DisplayName: 硫黄のブーメラン
				Tooltip:
					'''
					4枚のブーメランを扇状に投げ、カーソル周囲を旋回させる
					ステルス攻撃ではより広範囲を旋回し、敵を追尾する毒の雨の渦を発生させる
					'''
			}

			UrchinStinger: {
				DisplayName: ウニの針
				Tooltip:
					'''
					敵に突き刺さり、非常に強力な毒を注入する
					ステルス攻撃ではより長時間突き刺さり、毒を与える
					ステルス攻撃の針が刺さった敵に合計7本の針を刺すと、爆発が発生する
					'''
			}

			Vega: {
				DisplayName: ベガ
				Tooltip:
					'''
					命中時に砕けて星の破片となり、スターバーストを生成する槍を投げる
					ステルス攻撃ではリラの幻影を呼び出し、広範囲に莫大なダメージを与える
					<right>でスターバーストを20消費し、現在のステルス量に関係なく即座にステルス攻撃を発動する
					この攻撃はすべての星の破片を呼び寄せて対象を攻撃させ、[cbuff:CalamityMod/Voidfrost]を付与する
					ベガでスターバーストを消費すると、ローグ防具なしでも10秒間ステルスを使用できる
					「誤解された天才の最後の歌......あるいは狂人のそれか」
					'''
			}

			Whitewater: {
				DisplayName: 白水の瓶
				Tooltip:
					'''
					少し後に発光する魔法の水の瓶をカーソル位置へ投げる
					発光中に敵へ命中した瓶は、水の槍を4本放ち、瓶の位置へ収束させる
					敵に当たるか遠く離れすぎると、瓶は持ち主の元へ戻る
					ステルス攻撃では水の槍を6本生成し、プレイヤーを回復し敵をノックバックさせる白水の渦を発生させる
					渦に入った味方は回復時間が2倍になる
					'''
			}
			
			AdamantiteThrowingAxe: {
				DisplayName: アダマンタイトの投げ斧
				Tooltip: ステルス攻撃は敵に命中すると稲妻を召喚する
			}

			Apoctolith: {
				DisplayName: アポクトリス
				Tooltip:
					'''
					クリティカルヒットで敵の防御力を下げる
					ステルス攻撃は敵を短時間スタンさせる
					「顔でレンガを受け止めるのは、そんなにいいアイデアじゃないかも...」
					'''
			}

			AshenStalactite: {
				DisplayName: 灰色の鍾乳石
				Tooltip:
					'''
					小さな鍾乳石を投げるが、すぐに砕ける
					ステルス攻撃は、より大きく、よりダメージの大きい鍾乳石を投擲する
					'''
			}

			AuroradicalThrow: {
				DisplayName: オーロラディカルスロー
				Tooltip:
					'''
					分裂する星を投げる
					分裂した星は数秒後に近くの敵を追尾する
					ステルス攻撃は敵にヒットした時に流星を降らせる
					'''
			}

			BallisticPoisonBomb: {
				DisplayName: バリスティックポイズンボム
				Tooltip:
					'''
					トゲと毒煙を撒き散らす粘着爆弾を投げる
					ステルス攻撃は一度に3つ投擲する
					'''
			}

			BlastBarrel: {
				DisplayName: タル爆弾
				Tooltip:
					'''
					壁にぶつかると爆発する樽を投げる
					ステルス攻撃は、樽が3回バウンドするようになる
					「昔はこれを飛び越える人もいたらしい」
					'''
			}

			BloodsoakedCrasher: {
				DisplayName: 血まみれの斧
				Tooltip:
					'''
					重力の影響を受け、2回バウンドする斧を投げる
					斧は時間とともにスピードが上がるが、敵に当たるとスピードが落ちる
					敵に命中すると血のオーブを放出する
					血のオーブを回収すると[cbuff:PotionSickness]の持続時間を短縮する
					ステルス攻撃が敵にヒットすると追尾する血液が生成される
					'''
			}

			BouncingEyeball: {
				DisplayName: プニプニの目玉
				Tooltip:
					'''
					地面に跳ね返る目玉を投げる
					ステルス攻撃によって、眼球はより速く動き、より激しく跳ね返る
					ブラッドムーンの間はノックバックが更に強くなる
					'''
			}

			Brimblade: {
				DisplayName: ブリムブレード
				Tooltip:
					'''
					敵に当たると分裂する刃を投げる
					ステルス攻撃でさらに分裂し、煉獄の弾幕を発射する
					'''
			}

			BurningStrife: {
				DisplayName: バーニングストライフ
				Tooltip:
					'''
					シャドウフレイムのスパイクボールを投げる
					ステルス攻撃は命中すると触手が出現する
					「ポケットの中に入れると危険！」
					'''
			}

			CelestialReaper: {
				DisplayName: 天上の鎌
				Tooltip:
					'''
					追尾する鎌を投げる
					大鎌は敵に6回当たると跳ね返る
					ステルス攻撃は鎌の残像を生み出す
					'''
			}

			Celestus: {
				DisplayName: セレスタス
				Tooltip:
					'''
					敵に当たると分裂する鎌を投げる
					ステルス攻撃は敵にヒットした後、一度プレイヤーの元に戻り、再度敵に向かって飛んでいく
					'''
			}

			Cinquedea: {
				DisplayName: チンクエディア
				Tooltip: ステルス攻撃は敵に突き刺さった後、前方へ飛んでいき周囲を斬り裂く
			}

			CobaltKunai: {
				DisplayName: コバルトのクナイ
				Tooltip: ステルス攻撃は3本の追尾するコバルトクナイを投げる
			}

			ConsecratedWater: {
				DisplayName: 儀式用の水入り瓶
				Tooltip:
					'''
					聖なる水が入った瓶を投げる
					何かにぶつかると、聖なる炎の火柱を起こす
					ステルス攻撃は、爆発時に3本の炎柱を生み出す
					「埃っぽいボトルだ...」
					'''
			}

			CorpusAvertor: {
				DisplayName: コープスアヴァター
				Tooltip:
					'''
					短剣を投げ、跳ね返る分身を生成する
					ライフが低いほどダメージが増加し、ライフ吸収効果を得る
					ステルス攻撃は、虹色の短剣を一本投げ、その軌跡に血の代償を伴う追加の斬撃を発生させる
					この短剣は命中時、チームメンバーに10%ダメージ増加と毎秒ライフ+2の自然回復を付与し、与えたダメージの一部を回復させる
					「かなり摩耗しているようだ」
					'''
			}

			CosmicKunai: {
				DisplayName: コズミッククナイ
				Tooltip:
					'''
					射程の短いクナイを連続で放つ
					ステルス攻撃は5本のコズミックサイスを生み、爆発する
					'''
			}

			CraniumSmasher: {
				DisplayName: 頭蓋砕き
				Tooltip:
					'''
					爆発する円盤を投げることがある
					ステルス攻撃は、複数の敵を貫通し、爆発する
					'''
			}

			CrushsawCrasher: {
				DisplayName: クラッシュソー・クラッシャー
				Tooltip:
					'''
					バウンドする斧を投げる
					ステルス攻撃は一度に5つ投げる
					'''
				GFBFirstWords:
					'''
					クラッシュソー
					クラッシュソー
					クラッシュクロー
					クラッシュクロー
					クラッシュコー
					クラッシャー
					クラッシュモー
					クラッシュモー
					クローショー
					コールスロー
					カシュー
					コーコー
					クラブショー
					キャッスル
					キャットショー
					キャットスポー
					'''
				GFBLastWords:
					'''
					クラッシャー
					クラッシャー
					クラッシャー
					キャッシャー
					クラッカー
					キャッチャー
					トラッシャー
					ラッシャー
					クラッカー
					キャックラー
					チェッカー
					クリッカー
					キャッシャー
					'''
				GFBWordSeparator: "・"
			}

			Crystalline: {
				DisplayName: クリスタライン
				Tooltip:
					'''
					複数の短剣に分裂する
					ステルス攻撃は、短剣がより多く分裂し、クリスタルを生成する
					'''
			}

			CrystalPiercer: {
				DisplayName: クリスタルの槍
				Tooltip:
					'''
					無限に貫通する槍を投げる
					ステルス攻撃は重力を無視し、クリスタルの破片を召喚する
					'''
			}

			CursedDagger: {
				DisplayName: 呪われた短剣
				Tooltip:
					'''
					呪いの短剣と、精度の低い2本の短剣を素早く投げる
					ステルス攻撃は、呪われた炎の渦を引き起こす短剣を一本投げる
					'''
			}

			DeepSeaDumbbell: {
				DisplayName: 深海のダンベル
				Tooltip:
					'''
					ダンベルを投げ、バウンドするたびに重りを飛ばす
					<right> を押すと屈伸し、次の攻撃のダメージが最大5倍になる
					屈伸自体も敵に当たるとダメージを与えられる
					'''
			}

			DeepWounder: {
				DisplayName: 深みの斧
				Tooltip:
					'''
					命中した敵に大出血と圧潰を与える深淵の斧を投げる
					ステルス攻撃は、手斧が敵に突き刺さり、水の弾幕を放出する
					水の弾は短い遅延の後、最も近い敵へ向かって発射される
					'''
			}

			DefectiveSphere: {
				DisplayName: 不安定なスフィア
				Tooltip:
					'''
					さまざまな効果を持つ球体を投げる
					一度に最大5つの球体を投げることができる
					ステルス攻撃は、4種類の球体を一度に投げる
					'''
			}

			DesecratedWater: {
				DisplayName: 穢れた水入り瓶
				Tooltip:
					'''
					邪悪な泡を爆発させる水入り瓶を投げる
					ステルス攻撃は、霊液と呪炎を与える追加の泡を生み出す
					'''
			}

			DukesDecapitator: {
				DisplayName: 公爵の処刑斧
				Tooltip:
					'''
					敵に触れると切り裂く斧を投げる
					斧の回転が速いほど、消えるまでのヒット回数が増える
					ステルス攻撃は射程距離の短い泡を発生させる
					'''
			}

			DuststormInABottle: {
				DisplayName: 瓶詰めの砂嵐
				Tooltip:
					'''
					拡散する砂煙を発生させる
					ステルス攻撃は、より強力な砂煙を生成する
					'''
			}

			DynamicPursuer: {
				DisplayName: 演算追跡ブーメラン
				Tooltip:
					'''
					敵に電気を発射する計算処理ブーメランを投げる
					ステルス攻撃は、他のターゲットに跳ね返り、レーザーを発射し、爆発を起こす
					ブーメランが新しいターゲットを見つけられなかった場合、元のターゲットを追いかける
					'''
			}

			EclipsesFall: {
				DisplayName: 終焉の日蝕
				Tooltip:
					'''
					攻撃が命中すると、空から槍を召喚する
					ステルス攻撃は、敵を貫き、時間とともに絶え間ない槍の雨を召喚する
					「太陽が闇に包まれる時、あなたは審判を知るだろう」
					'''
			}

			EnchantedAxe: {
				DisplayName: エンチャントアックス
				Tooltip:
					'''
					高速で飛ぶ斧を投げ、一定距離が経過するか、壁に当たると戻ってくる
					プレイヤーから最も遠い地点で、魔法の斧が最も近くの敵に向かって放たれる
					ステルス攻撃はでは斧がさらに遠くまで飛び、全方向に多数の魔法の斧を投げる
					'''
			}

			EpidemicShredder: {
				DisplayName: 疫病の輪刃
				Tooltip:
					'''
					敵やブロックに当たるとプレイグシーカーを放つブーメランを投げる
					ステルス攻撃は、ブーメランが移動しながら常にプレイグシーカーを放つようになる
					「使い方を間違えれば伝染病を引き起こすだろう」
					'''
			}

			ExecutionersBlade: {
				DisplayName: 処刑人の手鎌
				Tooltip:
					'''
					追尾する刃を投げる
					ステルス攻撃はヒット時に刃のギロチンを召喚する
					'''
			}

			FantasyTalisman: {
				DisplayName: 幻想の札
				Tooltip:
					'''
					重力の影響を受けない高速の護符を放つ
					護符は敵に張り付き、復讐の魂を放って追跡させる
					ステルス攻撃時はより多くの魂を放ち、消滅時に迷える魂となって炸裂する
					「お前に賭けなくてよかったよ」
					'''
			}
