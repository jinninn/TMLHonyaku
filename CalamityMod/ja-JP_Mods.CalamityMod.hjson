				DisplayName: 砕光の夜明け
				Tooltip:
					'''
					投げたダガーは分裂し、追尾する
					ステルス攻撃は、ダガーが命中するとプレイヤーの位置から追尾するダガーの弾幕が放たれ、敵を吸い寄せる
					'''
			}

			ShinobiBlade: {
				DisplayName: 忍刀
				Tooltip:
					'''
					敵を倒すと回復オーブを生成する刀を投げる
					ステルス攻撃は、ランダムな方向から攻撃を繰り出す
					'''
			}

			SkyfinBombers: {
				DisplayName: フィッシュボンバーズ
				Tooltip:
					'''
					下にいる敵に追尾する核を発射する
					ステルス攻撃は、敵の位置に関係なく追尾するようになる
					「魚みたいな爆撃機が来たぞー！」
					'''
			}

			SlickCane: {
				DisplayName: 巧妙な杖
				Tooltip:
					'''
					杖を振るい、敵からお金を奪う
					ステルス攻撃は1/20の確率で、命中した敵が1～2ゴールドコインを落とす
					ステルス攻撃時は所持金に比例してダメージが増加する（最大1プラチナまで）
					「最高の経済」
					'''
			}

			SludgeSplotch: {
				DisplayName: 穢れたスライムの塊
				Tooltip: ステルス攻撃は、ヘドロが敵にヒットした時に分裂し、より大きなダメージを与えるようになる
			}

			SnapClam: {
				DisplayName: スナップクラム
				Tooltip:
					'''
					敵に取り付き、時間経過とともにダメージを与える
					ステルス攻撃は一度に5つのハマグリを投げ、時間の経過とともにダメージが増加する
					'''
			}

			SpearofDestiny: {
				DisplayName: 運命の槍
				Tooltip:
					'''
					3本の小さな追尾する槍と、1本の貫通する槍を交互に投擲する
					ステルス攻撃はヒット時に爆発する聖槍を投げる
					'''
			}

			SpearofPaleolith: {
				DisplayName: 旧石器時代の槍
				Tooltip:
					'''
					敵の鎧を破壊する古代の槍を投げる
					化石の破片を放つ
					ステルス攻撃は、速度は遅いがより遠くまで届く化石の破片を放つ
					'''
			}

			SpentFuelContainer: {
				DisplayName: 使用済み燃料コンテナ
				Tooltip:
					'''
					核爆発を引き起こす微量のプルトニウムが入った燃料容器を投げる
					下にブロックがない場合、爆発は起こらない
					ステルス攻撃は、爆発が消滅した後にも汚染エリアが残る
					「戦争は...決して変わらない」
					'''
			}

			StellarKnife: {
				DisplayName: 星のナイフ
				Tooltip:
					'''
					ある程度の高さで止まり、敵に飛んでいくナイフを投げる
					ステルス攻撃は10本のナイフを投げつける
					「ザ・ワールド！」
					'''
			}

			StormfrontRazor: {
				DisplayName: ストームフロントレイザー
				Tooltip:
					'''
					命中時に雷を召喚するナイフを投げる
					ステルス攻撃はナイフのスピードが上がり、ヒット時に複数の稲妻を召喚する
					[c/24C7F0:「攻撃で流れを止めろ」]
					'''
			}

			SubductionSlicer: {
				DisplayName: サブダクションスライサー
				Tooltip:
					'''
					敵に当たると爆発する鎌を投げる
					ステルス攻撃は敵にヒットするとオレンジ色の火柱を召喚する
					'''
			}

			Supernova: {
				DisplayName: スーパーノヴァ
				Tooltip:
					'''
					投げた後、近くの敵に飛んでいって爆発する
					敵が見つからなければ、自分のところに戻ってくる
					ステルス攻撃は、宇宙の根幹を揺るがすような大爆発を引き起こす
					'''
			}

			TarragonThrowingDart: {
				DisplayName: タラゴンのダーツ
				Tooltip:
					'''
					無敵時間を減少させる貫通ダーツを放つ
					ステルス攻撃は敵に命中するとトゲを生やす
					'''
			}

			TerrorTalons: {
				DisplayName: 恐怖のツメ
				Tooltip:
					'''
					小さくゆらめく爪を放つ
					ステルス攻撃は、大きな爪を素早く放つ
					'''
			}

			TheAtomSplitter: {
				DisplayName: アトムスプリッター
				Tooltip:
					'''
					量子重複状態のジャベリンを投げ、複数の時間軸から同時に攻撃する
					ステルス攻撃は更に多くの同時攻撃を行う
					'''
			}

			TheFinalDawn: {
				DisplayName: 夜明けの鎌
				Tooltip:
					'''
					巨大な鎌を振り回し、攻撃がヒットするとステルスが回復する
					上キーと攻撃ボタンを押すと鎌を投げる
					ステルス攻撃は横方向に振り抜き、炎を残す
					上キーを押しながらステルス攻撃を行うと敵に斬りかかり、追尾する火の玉を発生させる
					「我らは再び朝日に向かって進むのだ」
					'''
			}

			TheSyringe: {
				DisplayName: 汚染された注射器
				Tooltip:
					'''
					時間経過でダメージが増加する注射器を投げる
					何かにぶつかるとガラスと疫病の燃え殻を撒き散らす
					ステルス攻撃は粉々になったあとに疫病蜂を放つようになる
					「体に悪そうだ...」
					'''
			}

			ThrowingBrick: {
				DisplayName: レンガブロック
				Tooltip:
					'''
					ステルスが最大の場合、レンガが当たると砕け散る
					「丈夫かどうか知りたきゃ、一回顔で受け止めてみな」
					'''
			}

			TimeBolt: {
				DisplayName: タイムボルト
				Tooltip:
					'''
					時間を歪ませるナイフを投げる
					ステルス攻撃は、より多くの敵に命中し、更に大きなタイムフィールドを作り出すことができる
					「人間の努力に限界はないはずだ」
					'''
			}

			TitaniumShuriken: {
				DisplayName: チタンの手裏剣
				Tooltip: ステルス攻撃は、敵に当たると分裂する
			}

			ToothBall: {
				DisplayName: 肉のボール
				Tooltip: ステルス攻撃で敵に命中すると雨雲が発生する
			}

			TotalityBreakers: {
				DisplayName: タール入りの瓶
				Tooltip:
					'''
					可燃性の黒いタールを爆発させる
					黒いタールは敵に油をまとわせ、火をつける
					ステルス攻撃は更に多くの黒いタールを撒き散らすようになる
					「もっと大きな破壊力が必要だ」
					'''
			}

			ToxicantTwister: {
				DisplayName: 硫黄のブーメラン
				Tooltip:
					'''
					ゆっくり動くブーメランを投げる
					しばらくの後、ブーメランは敵に向かって飛んでいく
					ステルス攻撃は、より速く飛んでいき、砂を放つ
					'''
			}

			Turbulance: {
				DisplayName: 蒼天の槍
				Tooltip:
					'''
					槍を投げ、敵にヒットすると風斬りを放つ
					クリティカルヒットした場合、風の刃は追尾する
					ステルス攻撃は、風斬りが追尾するようになる
					'''
			}

			TwistingThunder: {
				DisplayName: ツイスティングサンダー
				Tooltip:
					'''
					敵を感電させる稲妻を放つ
					雨が降っている時、稲妻はより素早く移動する
					何かにぶつかると空から稲妻を召喚する
					ステルス攻撃はより多くの稲妻を召喚し、より速く移動する
					'''
			}

			UtensilPoker: {
				DisplayName: ポーカーの調理器具
				Tooltip:
					'''
					調理器具を3回投げる
					ステルス攻撃は、投げる調理器具が全て肉切り包丁になる
					「宇宙のニワトリ！」
					'''
			}

			Valediction: {
				DisplayName: 告別の鎌
				Tooltip:
					'''
					追尾する死神鎌を投げる
					ステルス攻撃は敵のヒット時に剃刀のような台風を生み出す
					'''
			}

			WaveSkipper: {
				DisplayName: ウェーブスキッパー
				Tooltip:
					'''
					よく跳ねる槍を投げる
					ステルス攻撃は3本の高速槍を投げる
					'''
			}

			WebBall: {
				DisplayName: クモの巣ボール
				Tooltip:
					'''
					敵をクモの巣で覆い、動きを鈍らせるクモの巣ボールを投げる
					ステルス攻撃は敵の動きを遅くする時間が長くなる
					'''
			}

			Wrathwing: {
				DisplayName: ラースウイング
				Tooltip:
					'''
					常に火を噴き続ける、追尾する有翼の槍を投げる
					ステルス攻撃はヒット時に噴火を起こす
					'''
			}

			WulfrumKnife: {
				DisplayName: ウルフラムのナイフ
				Tooltip:
					'''
					ウルフラムナイフを3本連続で投げる
					ステルス攻撃はナイフをより遠くへ飛ばし、一度に何回もヒットさせる
					<right>を押し続けると、近くに落ちているナイフをすべて磁力で自分の元に戻し、ステルスを回復する
					ナイフが戻ってくると、一時的にローグ防具なしでもステルス攻撃が可能になる
					'''
			}
		}

		Summon: {
			AmphibiansGuitar: {
				DisplayName: 両生類のギター
				Tooltip:
					'''
					最大8本のギターを召喚し、自身の周囲を回転しながら標的へ音符を発射、時折拡散弾も放つ
					8本すべて揃うと一部の音符が強化され、追加ダメージを与える
					「苦しんでいるところを見せてやる！」
					'''
			}

			EnchantedKnifeStaff: {
				DisplayName: エンチャントナイフの杖
				Tooltip: 共に戦う魔法の短剣を召喚する
			}

			DazzlingStabberStaff: {
				DisplayName: 聖刃の杖
				Tooltip:
					'''
					共に戦う冒涜の素材で作られた3本の聖なる短剣を召喚する
					聖炎の短剣は勇ましく敵を灰へと変える
					結晶の短剣は優雅に敵を切り刻む
					冒涜の短剣は荒々しく砕け散り、永遠に再生する
					「ただひたすらに、彼女の望む未来へ」
					'''
			}

			SanctifiedSpark: {
				DisplayName: 冒涜の聖炎
				Tooltip:
					'''
					冒涜の使者を召喚し、プレイヤー付近で漂う
					冒涜の使者は近くの敵に追尾するフレアを素早く連射する
					攻撃後、所持している召喚スロット4ごとに1発、回復魔法をプレイヤーへ放つ
					「少しベタつくけど、少なくとも暖かい」
					'''
			}

			SarosPossession: {
				DisplayName: 陰の太陽の杖
				Tooltip:
					'''
					原初の光の力を宿す輝くオーラを召喚する
					繰り返し召喚することでオーラの力が増す
					オーラが最大のときに<left>で、時間経過で減衰する日食ビームを放つ
					このビームは使用していない間に再充填される
					'''
			}

			Sirius: {
				DisplayName: シリウス
				Tooltip:
					'''
					夜空で最も明るい星、シリウスを召喚して守らせる
					さらに召喚を続けると、おおいぬ座を完成させる
					星座完成後も、繰り返し召喚することで大幅に強化される
					シリウスは敵を狙うとパッシブでスターバーストを生成する
					スターバーストが最大になると消費し、[cbuff:CalamityMod/Voidfrost]を付与する強力な貫通魔法を放つ
					「叶わなかった夢への道標」
					'''
			}

			SunSpiritStaff: {
				DisplayName: 太陽の杖
				Tooltip:
					'''
					太陽の精霊を召喚して守らせる
					繰り返し召喚することで力が増す
					'''
			}

			ViridVanguard: {
				DisplayName: ヴィリッドヴァンガード
				Tooltip:
					'''
					強力な毒を帯びた斧と剣を交互に召喚する
					斧はプレイヤーの周囲を旋回し、近距離で高ダメージを与える
					剣は極めて正確に敵を追尾し、切り刻む
					すべての武器は毒を付与し、召喚数が増えるほど強力になる
					ミニオンスロットがすべて埋まっている状態で再度<left>を押すと、カーソルへ向けて連続斬撃を放つ
					この能力には5秒のクールダウンがあり、このアイテムを所持している必要がある
					インベントリ内でShift＋<right>すると回転方向を変更できる
					'''
			}

			VoidEaterMarionette: {
				DisplayName: 虚無喰いの杖
				Tooltip:
					'''
					小型の貪食者を操る力を宿す
					繰り返し召喚することで貪食者の長さと攻撃力が増す
					貪食者は[c/ff00ff:神性を貪る者]、[c/ff00ff:信仰を焼き尽くす炎]、[c/ff00ff:超宇宙の渦潮]で攻撃する
					ドロップしたアイテムを回収させることができる
					貪食者を召喚した後、インベントリ内でShift＋<right>すると回収を優先させる
					'''
			}

			AbandonedSlimeStaff: {
				DisplayName: 見捨てられたスライムの杖
				Tooltip:
					'''
					使用時に残りのミニオンスロットをすべて消費する
					ホットバーから使用する必要がある
					ミニオンスロットの数に応じて強化される
					この武器を持つと、ジャンプ速度が10%増加する
					「天から投げ捨てられたこの遺物は、静かな悲劇を歌っている...」
					'''
			}

			AncientIceChunk: {
				DisplayName: 古代の氷塊
				Tooltip:
					'''
					共に戦うアイスクラスパーを召喚する
					遠くの敵に向かって氷の破片を発射する
					敵に接近している間、凍てつく怒りで積極的に敵を攻撃する
					'''
			}

			AquasScepter: {
				DisplayName: 嵐の杖
				Tooltip:
					'''
					巨大な嵐雲を召喚し、敵に雨を降らせ、近くの敵に稲妻を落とす
					「船長！雨が降るかもしれません！」
					'''
			}

			AresExoskeleton: {
				DisplayName: アレスのエクソスケルトン
				Tooltip:
					'''
					武装選択ができるコントロールパネルを表示する： プラズマ、テスラ、レーザー、ガウス
					武装の一つをクリックし、次にいずれかのスロットをクリックすると、そのタイプの武装が召喚される
					すでに埋まっているスロットをクリックすると、関連する武装が解除され、スロットが空になる
					武装はそれぞれミニオンのスロットを3つ使用する
					'''
			}

			AtlasMunitionsBeacon: {
				DisplayName: アトラスの軍需品ビーコン
				Tooltip:
					'''
					[c/F2B629:エクソパワーで動作する固定砲台を展開する]
					[c/F2B629:砲台は射程内の敵を攻撃する]
					[c/F27049:敵が近接している場合、砲台はオーバードライブモードに突入する]
					[c/F27049:オーバードライブ中は、砲台は最大出力で敵を撃破する]
					[c/F27049:オーバードライブ中、砲台は熱を蓄積し、最終的にはオーバーヒートする]
					[c/69F0DC:このアイテムを持っている状態で右クリックすると、自分で使用できる]
					[c/69F0DC:操作中は、砲台は常にオーバードライブ状態になる]
					[c/69F0DC:砲台が過熱すると、使用不可能になる]
					[c/9AA4AE:<right> を押すとで手動で砲台を手放すことができる]
					[c/9AA4AE:ベース近くで手放すと、自動的に再設置される]
					「予想より軽い」
					'''
			}

			BelladonnaSpiritStaff: {
				DisplayName: ベラドンナの精霊の杖
				Tooltip: 共に戦う森の精霊を召喚する
			}

			BlackHawkRemote: {
				DisplayName: ブラックホーク呼出装置
				Tooltip:
					'''
					共に戦うブラックホークを召喚する
					インベントリの弾丸を消費する
					50%の確率で弾薬を消費しない
					'''
			}

			BorealisBomber: {
				DisplayName: ボレアリスボンバー
				Tooltip:
					'''
					共に戦う不安定な惑星を召喚する
					惑星は、敵にぶつかると大爆発する
					ミニオンスロットを消費しない
					'''
			}

			BrittleStarStaff: {
				DisplayName: もろいヒトデの杖
				Tooltip:
					'''
					共に戦う小さなヒトデを召喚する
					ヒトデはすぐ壊れるが、すぐに再生する
					右クリックを押し続けるとヒトデの動きが変わる
					ヒトデが旋回しているときは、1匹につき3の防御力を得ることができる
					'''
			}

			CadaverousCarrion: {
				DisplayName: 屍肉の杖
				Tooltip: グロいサメを吐くオールドデュークの頭を地面に召喚する
			}

			CalamarisLament: {
				DisplayName: カラマリのラメント
				Tooltip: "[GFB]"
				TooltipNormal:
					'''
					共に戦うミニイカを召喚し、敵をインク漬けにする
					遠距離では、イカは追尾するインク弾を発射する
					近距離では、イカが敵に引っ付いて与えるダメージが増加する
					「深淵では、あらゆる資源が不足している
					　どの種も孤独だ。分け合うには少なすぎる...」
					'''
				TooltipGFB: 「マンメンミ！」
			}

			CausticCroakerStaff: {
				DisplayName: 腐食カエルの杖
				Tooltip: 近くに敵がいると爆発するヒキガエルを召喚する
			}

			CausticStaff: {
				DisplayName: 腐食の杖
				Tooltip:
					'''
					共に戦うドラゴンを召喚する
					いくつかの衰弱デバフを与える
					デバフは、召喚武器や道具を持っている場合にのみ適用される
					'''
			}

			CinderBlossomStaff: {
				DisplayName: 花の余燼の杖
				Tooltip:
					'''
					頭上に灼熱の花を召喚する
					花は1体までしか呼び出せない
					'''
			}

			CindersOfLament: {
				DisplayName: 嘆きの残り火
				Tooltip:
					'''
					共に戦う魔女の兄弟を召喚する
					彼らは一瞬こちらを見た後、プレイヤーに突進してくる
					彼らはプレイヤーと敵の両方にダメージを与えることができる
					[c/C61B40:「己が罪を作り出し、]
					[c/C61B40:　その心の中に悪魔を宿し、終わりなき時まで耐え忍ぶ」]
					'''
				Calamitas:
					'''
					私の兄弟はアザフレで命を落とした。遠征に出たあと、街の中心近くでその亡骸を見つけた。
					今ほどの力を持たなかった頃、あいつらはいつも私のそばにいて、誰にも指一本触れさせなかった。
					少々行き過ぎることもあったが......驚くほど従順だった。
					すべてを失った今も、死してなお、あいつらは私を守ろうとする。
					...健気なものだな。
					'''
			}

