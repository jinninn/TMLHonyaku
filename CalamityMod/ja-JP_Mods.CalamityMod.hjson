Common: {
	RogueDamage: ローグダメージが{0}%増加
	RogueCrit: ローグクリティカル率が{0}%上昇
	RogueDamageCrit: ローグダメージとクリティカル率が{0}%増加
	RogueVelocity: ローグ弾速が{0}%増加
