Configs: {
	CalamityClientConfig: {
		DisplayName: クライアント設定

		Headers: {
			Gameplay: ゲームプレイ全般の変更
			Graphics: グラフィック変更
			UI: UI変更
			MeterPositions: メーター位置
			MusicToggles: 音楽の再生設定
		}

		AbyssLayer3Alt: {
			Label: "[i:CalamityModMusic/AbyssLayer3AltMusicBox] 深淵3層代替曲"
			Tooltip: 深淵3層でCalamity Mod OST - 「R'lyehian Depths」を再生します
		}

		AdrenalineMeterPosX: {
			Label: "[i:LaserRuler] アドレナリンメーターのX位置"
			Tooltip:
				'''
				アドレナリンメーターのX位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		AdrenalineMeterPosY: {
			Label: "[i:LaserRuler] アドレナリンメーターのY位置"
			Tooltip:
				'''
				アドレナリン・メーターのY位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		Afterimages: {
			Label: "[i:SteampunkGoggles] 残像"
			Tooltip:
				'''
				NPCやプロジェクブロックなどの残像のレンダリングを有効にします
				無効にするとパフォーマンスが向上します
				'''
		}

		BossHealthBarExtraInfo: {
			Label: "[i:CalamityMod/EncryptedSchematicPlanetoid] ボスライフバー追加情報"
			Tooltip:
				'''
				Calamityのボスのライフバーに追加情報を表示
				これはボスの正確なライフか、残りのパーツやセグメントの数を表示します
				'''
		}

		ChargeMeter: {
			Label: "[i:CalamityMod/DraedonPowerCell] チャージメーターを表示"
			Tooltip:
				'''
				プレイヤーが保持している武器のチャージ量を表示するチャージメーター UI を有効にします
				チャージを必要とする武器を持っていない場合、チャージメーターは非表示になります
				'''
		}

		ChargeMeterPosX: {
			Label: "[i:LaserRuler] チャージメーターのX位置"
			Tooltip:
				'''
				チャージメーターの X 位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		ChargeMeterPosY: {
			Label: "[i:LaserRuler] チャージメーターのY位置"
			Tooltip:
				'''
				チャージメーターのY位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		CooldownDisplay: {
			Label: "[i:CalamityMod/NebulousCore] クールダウン表示モード"
			Tooltip:
				'''
				バフやデバフの下に重要なクールダウンを表示するクールダウンマークを追加します
				これを1に設定するとクールダウンマークがコンパクトに表示され、0に設定すると完全に非表示になります
				'''
		}

		DebuffDisplay: {
			Label: "[i:FlaskofIchor] 敵のデバフを表示"
			Tooltip: 敵の上にデバフアイコンのマークを追加します
		}

		DevourerofGodsEulogy: {
			Label: "[i:CalamityModMusic/DevourerofGodsEulogyMusicBox] Eulogy for the Egoの再生設定"
			Tooltip: Calamity Mod OST - 「Scourge of The Universe (Eulogy for The Ego)」をDoG討伐後に再生します
		}

		DisableGravityScreenSwap: {
			Label: 重力反転時の画面反転を無効化
			Tooltip:
				'''
				重力変更時に画面全体が反転するバニラの仕様を無効にし、代わりにプレイヤーのみを反転させます
				画面反転が見づらい、または酔いやすい場合に有効にしてください
				'''
		}

		EnableVanillaTextureEdits: {
			Label: "[i:Paintbrush] バニラテクスチャの調整を有効化"
			Tooltip:
				'''
				攻撃の予兆を分かりやすくするために、バニラボスのテクスチャに軽微な調整を加えます
				テクスチャパックとの互換性を優先する場合は無効にしてください
				'''
		}

		EnergyShieldOpacity: {
			Label: "[i:CalamityMod/TheSponge] エネルギーシールドの不透明度"
			Tooltip:
				'''
				プレイヤーに表示されるエネルギーシールドの透明度を設定します
				0に設定するとシールドの視覚効果が完全に無効になります
				'''
		}

		FancyBackgroundVisuals: {
			Label: "[i:CalamityMod/BlueDistortedMonolith] 高度な背景演出の切り替え"
			Tooltip:
				'''
				ボス戦など特定の場面で表示される特殊な背景演出の有無を設定します
				無効にすると一部の場面で簡略化された演出になります
				視認性に問題がある場合や動作が重い場合は無効推奨です
				'''
		}

		FasterFallHotkey: {
			Label: "[i:CalamityMod/BallAndChain] 高速落下の有効化"
			Tooltip:
				'''
				この設定を有効にすると、空中でDOWNキーを押し続けることで、下方向への加速が速くなります
				この設定によって最大落下速度が速くなるわけではなく、その速度まで加速するのが速くなるだけです
				Calamityはこの設定を有効にすることを前提に設計されています
				'''
		}

		FlightBar: {
			Label: "[i:CalamityMod/WingsofRebirth] フライトバーの表示"
			Tooltip:
				'''
				プレイヤーの残り翼飛行時間を表示するフライトバーUIを有効にします
				このバーは、デバフによって最大飛行時間が減少した場合にも表示されます
				最大飛行時間が無制限の場合は青く光ります
				'''
		}

		FlightBarPosX: {
			Label: "[i:LaserRuler] フライトバーX位置"
			Tooltip:
				'''
				フライトバーの X 位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		FlightBarPosY: {
			Label: "[i:LaserRuler] フライトバーY位置"
			Tooltip:
				'''
				フライトバーのY位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		Interludes: {
			Label: "[i:CalamityModMusic/Interlude1MusicBox] 間奏曲"
			Tooltip:
				'''
				ゲーム内で3つの間奏曲を有効にします：
				カラミタスクローンを討伐した後にCalamity Mod OST - 間奏曲 1、「Silence before the storms」を再生
				ムーンロードを討伐した後にCalamity Mod OST - 間奏曲 2, 「Storms before the catastrophes」を再生
				ヤーロンを討伐した後にCalamity Mod OST - 間奏曲 3, 「Catastrophes before the calamity」を再生
				'''
		}

		MeterPosLock: {
			Label: "[i:GemLockTopaz] メーター位置のロック"
			Tooltip:
				'''
				画面上のCalamityの各種メーターをクリックできないようにします
				これにより、マウスでドラッグすることができなくなります
				'''
		}

		ParticleLimit: {
			Label: "[i:FragmentStardust] 最大パーティクルリミット"
			Tooltip:
				'''
				一度に存在できるパーティクル効果の最大値を設定します
				パーティクルはダストやゴアとは別物です
				パフォーマンスを向上させるには下げます
				'''
		}

		Photosensitivity: {
			Label: "[i:DiscoBall] 光過敏症モード"
			Tooltip:
				'''
				一部の視覚エフェクトの明るさや点滅を軽減または無効にします
				すべての画面揺れ効果も無効になります
				光に敏感な方には特に推奨されます
				'''
		}

		RageMeterPosX: {
			Label: "[i:LaserRuler] レイジメーターX位置"
			Tooltip:
				'''
				レイジメーターの X 位置を変更できます
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		RageMeterPosY: {
			Label: "[i:LaserRuler] レイジメーターY位置"
			Tooltip:
				'''
				レイジメーターのY位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		RipperMeterShake: {
			Label: "[i:CalamityMod/RedLightningContainer] レイジとアドレナリンメーターの揺れ"
			Tooltip:
				'''
				使用中のレイジメーターとアドレナリンメーターの揺れ具合。
				ゼロに設定すると、揺れを完全に無効にすることができます
				'''
		}

		ScreenshakePower: {
			Label: "[i:CalamityMod/WavePounder] 画面の揺れ"
			Tooltip:
				'''
				画面揺れの強さ
				ゼロに設定すると完全に無効になります
				[c/FF232C:すべての画面揺れのビジュアルは、1の値を中心にバランスが取られています]
				[c/FF232C:高い数値は吐き気を催すなど、人によっては気分が悪くなるかもしれません]
				'''
		}

		SetBonusDoubleTap: {
			Label: "[i:VortexHelmet] アーマーセットボーナスにダブルタップを許可"
			Tooltip: バニラの下キーをダブルタップ（設定によっては上キーの場合もあります）ですべての防具セットボーナスを発動できるようにします
		}

		ShopNewAlert: {
			Label: "[i:GoldChest] 新アイテム入荷のお知らせ"
			Tooltip: タウンNPCのショップに新しいアイテムが追加されたとき、その上にアイコンが表示されるようにします
		}

		SpeedrunTimer: {
			Label: "[i:Stopwatch] スピードランタイマーを表示"
			Tooltip:
				'''
				ゲーム内の時間をミリ秒単位で表示するスピードランタイマーを有効にします
				2行目には最新のボスを倒した時間が表示されます
				時間はプレイヤーごとに追跡され、ワールドがロードされている間のみカウントされます
				'''
		}

		SpeedrunTimerPosX: {
			Label: "[i:LaserRuler] スピードランタイマーX位置"
			Tooltip:
				'''
				スピードランタイマーのX位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		SpeedrunTimerPosY: {
			Label: "[i:LaserRuler] スピードランタイマーY位置"
			Tooltip:
				'''
				スピードランタイマーのY位置を変更します
				メーター位置のロックが無効の場合、メーターはマウスでドラッグできます
				'''
		}

		StealthInvisibility: {
			Label: "[i:CalamityMod/StealthHairDye] ステルス・インビジビリティー"
			Tooltip:
				'''
				ローグのステルスゲージが増加するにつれて、プレイヤーが徐々に透明になっていきます
				この効果はシュルームアーマーのステルスに似ています
				'''
		}

		StealthMeter: {
			Label: "[i:CalamityMod/EclipseMirror] ステルスメーター表示"
			Tooltip:
				'''
				プレイヤーの現在のステルスレベルを表示するステルスメーターUIを有効にします
				ローグアーマーを着用していない場合、ステルスメーターは常に非表示になります
				'''
		}

		StealthMeterPosX: {
			Label: "[i:LaserRuler] ステルスメーターX位置"
			Tooltip:
				'''
				ステルスメーターのX位置を変更します
				メーターの位置をロックする機能が無効の場合、メーターはマウスでドラッグできます
				'''
		}

		StealthMeterPosY: {
			Label: "[i:LaserRuler] ステルスメーターY位置"
			Tooltip:
				'''
				ステルスメーターのY位置を変更する。
				メーターの位置をロックする機能が無効の場合、メーターはマウスでドラッグできます
				'''
		}

		StutterFix: {
			Label: "[i:TrifoldMap] カクつき防止機能を有効化"
			Tooltip:
				'''
				有効にすると、ワールド入場時に全体を一度に読み込みます
				読み込み中はTerrariaが一時的に応答しなくなりますが、絶対にゲームを終了しないでください
				応答が戻るとワールドに入場し、その後はランダムなカクつきが発生しにくくなります
				プレイ中のカクつきが我慢できない場合のみ推奨されます
				'''
		}

		SulphuricWaterMeterPosX: {
			Label: "[i:LaserRuler] 硫黄水毒メーターX位置"
			Tooltip:
				'''
				硫酸水毒メーターのXの位置を変更します
				メーターの位置をロックする機能が無効の場合、メーターはマウスでドラッグできます
				'''
		}

		SulphuricWaterMeterPosY: {
			Label: "[i:LaserRuler] 硫黄水毒メーターY位置"
			Tooltip:
				'''
				硫酸水毒メーターのY位置を変更できます
				メーターの位置をロックする機能が無効の場合、メーターはマウスでドラッグできます
				'''
		}

		SunkenSeaBackgroundDistortion: {
			Label: "[i:CalamityMod/SeaRemains] 沈没海の背景の歪み効果"
			Tooltip:
				'''
				サンケンシーの専用背景に追加の歪みシェーダーを適用するかどうかを設定します
				水中の揺らぎのような演出になります
				[c/FF232C:"Wave Quality"設定がオフの場合のみ機能します]
				'''
		}

		TextEffects: {
			Label: "[i:LeinforsAccessory] 追加テキストエフェクト"
			Tooltip:
				'''
				有効にすると、一部のCalamityレアリティに特殊な視覚効果が表示されます
				視覚的な煩雑さを減らしたい場合は無効にしてください
				'''
		}

		TileTextureBlendingQuality: {
			Label: "[i:GlowPaint] ブロック結合のソフトブレンド品質"
			Tooltip: 異なる種類のブロックが接合する際に使用されるソフトブレンド描画の品質を変更します
		}

		VanillaCooldownDisplay: {
			Label: "[i:HealingPotion] バニラのクールダウンを表示"
			Tooltip:
				'''
				Cooldown Rackにバニラデバフのポーション酔いとカオス状態を追加します
				デバフはバフアレイに表示されるが、より見やすくします
				'''
		}

		VCMMStatusMessage: {
			Label: "[i:MusicBoxMartians] VCMMステータスメッセージ"
			Tooltip: ワールドに入る際に再生される、Vanilla Calamity Music Modのステータスメッセージを有効または無効にします。
		}

		WikiStatusMessage: {
			Label: "[i:Book] Wikiステータスメッセージ"
			Tooltip: ワールドロード時に流れるOfficial Calamity Wikiを宣伝するステータスメッセージを有効または無効にします
		}
	}

	CalamityServerConfig: {
		DisplayName: サーバー設定
		Denied: この設定を変更する権限がありません

		Headers: {
			ExpertMaster: エキスパートおよびマスター難易度の変更
			Gameplay: 一般的なゲームプレイの変更
			BaseBoosts: 基本ステータスの強化
		}

		BossesStopWeather: {
			Label: "[i:CalamityMod/TorrentialTear] ボス戦中の天候"
			Tooltip:
				'''
				有効にすると、ゲーム終盤のボスの多くがスポーン時にすべての雨と関連する天候を止める
				ゲーム終盤のボス戦でパフォーマンスに問題がある場合は有効にするのがおすすめ
				'''
		}

		BossHealthBoost: {
			Label: "[i:LifeCrystal] ボスのライフブースト率"
			Tooltip:
				'''
				全てのボスのライフを指定されたパーセンテージだけブーストします
				これはマルチプレイヤーのボスのライフブーストと重複します
				すでにスポーンしているボスには影響しない
				'''
		}

		DefaultDashEnabled: {
			Label: "[i:Tabi]デフォルトダッシュ"
			Tooltip:
				'''
				デフォルトで装備やアイテムを必要としない非常に弱いダッシュを使用可能にします
				このダッシュは他のMODのものも含め、使用可能な他のダッシュに置き換えられます
				'''
		}

		BossZen: {
			Label: "[i:CalamityMod/ZenPotion] ボス戦中スポーン率"
			Tooltip:
				'''
				ボス戦は、通常の敵のスポーン率を激減させます
				また、ボスが生きている間はSlime Rainが発生しなくなります
				Calamityはこの設定を有効にすることを前提に設計されています
				'''
		}

		ChilledWaterRework: {
			Label: "[i:ArcticDivingGear] 冷水リワーク"
			Tooltip: 有効にすると、雪バイオームにある水は、凍えを与え、プレイヤーの酸素を急速に消耗させます
		}

		EarlyHardmodeProgressionRework: {
			Label: "[i:Pwnhammer] 初期ハードモード進行のリワーク"
			Tooltip:
				'''
				悪魔の祭壇が壊れても鉱石や真紅/不浄ブロックをスポーンしなくなります
				ウォールオブフレッシュが初回討伐時にコバルトとパラジウム鉱石を生成するようになります
				最初に戦うメカのボスのライフとダメージが20%減少し、初回討伐時にミスリルとオリハルコン鉱石を生成します
				2体目のメカボスはライフとダメージが10%減少し、初回キル時にアダマンタイトとチタン鉱石を生成します
				3体目のメカボスは初回討伐時に聖なる鉱石を生成します
				'''
		}

		FasterBaseSpeed: {
			Label: "[i:HermesBoots] 基本移動速度を上げる"
			Tooltip:
				'''
				常に移動速度を+50%することで、プレイヤーの基本移動速度を大幅に増加させます
				この設定はTerraria Overhaulがロードされている場合は何もしません
				Calamityはこの設定を有効にすることを前提に設計されています
				'''
		}

		FasterRopeClimbSpeed: {
			Label: "[i:Rope] ロープ登り速度を上昇"
			Tooltip:
				'''
				ロープ上での加速・減速を強化し、ロープ登り速度を大幅に向上させます
				Calamityはこの設定を有効にする前提でバランス調整されています
				'''
		}

		FasterJumpSpeed: {
			Label: "[i:FrogLeg] ベースジャンプのスピードを上げる"
			Tooltip:
				'''
				プレイヤーの基本ジャンプ速度をわずかに上げます
				Calamityはこの設定を有効にすることを前提に設計されています
				'''
		}

		FasterTilePlacement: {
			Label: "[i:ArchitectGizmoPack] ブロック設置スピードの向上"
			Tooltip:
				'''
				プレイヤーがブロックや壁を配置する速度を大幅に増加させます
				この設定は建築系アクセサリーと効果が重複します
				'''
		}

		ForceTownSafety: {
			Label: "[i:Sunflower] 街の安全性"
			Tooltip:
				'''
				エキスパートモードとマスターモードでは、敵が町の近くでスポーンしやすくなるため、スポーン率が大幅に低下します
				これは、生き物を見つけるのが難しくなるなど、意図しない副作用をもたらす可能性があります
				'''
		}

		NerfExpertDebuffs: {
			Label: "[i:AnkhCharm] デバフ持続時間増加の削除"
			Tooltip:
				'''
				Expertモードではデバフの持続時間が2倍（Masterモードでは3倍）になります
				Calamityはこの設定を有効にすることを前提に設計されています
				'''
		}

		RemoveLavaDropsFromLavaSlimes: {
			Label: "[i:LavaWaders] ラーヴァスライムから溶岩のしずくを取り除く"
			Tooltip: 有効にすると、ラーヴァスライムは溶岩を落とさない新しいラーヴァスライムに置き換わります
		}

		RemoveReforgeRNG: {
			Label: "[i:TinHammer] リフォージのランダム性の削除"
			Tooltip:
				'''
				ゴブリンのよろず屋の武器とアクセサリーのリフォージからランダム性を取り除きます
				競合を防ぐため、独自にリフォージを変更するMODを使用している場合は無効にしてください
				'''
		}

		PlayerRespawnTime_BossAlive: {
			Label: "[i:Stopwatch] ボス戦闘時のリスポーンタイマー"
			Tooltip:
				'''
				ボスが生きているときのプレイヤーのリスポーン時間を秒単位で設定します。これはシングルプレイヤーでもマルチプレイでも同様に適用されます
				ボスが生存していない場合、プレイヤーはシングルプレイヤーでもマルチプレイでも3秒でリスポーンします
				'''
		}

		SimplifyAccessoryReforge: {
			Label: "[i:Autohammer] アクセサリー修繕簡略化"
			Tooltip:
				'''
				アクセサリーの修繕候補を以下の接頭辞のみに制限します：
				- Warding, Menacing, Lucky, Quick, Violent, Arcane, Silent, Invigorating, Dauntless
				'''
		}

		TownNPCSpawnRateMultiplier: {
			Label: "[i:GuideVoodooDoll] タウンNPCのスポーン率倍率"
			Tooltip:
				'''
				町のNPCがスポーン、リスポーンするレートを直接乗算します
				これにより、ボスやイベントで町が全滅した場合の待ち時間が短縮されます
				'''
		}

		TownNPCsSpawnAtNight: {
			Label: "[i:ClothierVoodooDoll] タウンNPC夜間スポーン設定"
			Tooltip:
				'''
				有効にすると、町のNPCが夜にスポーン、リスポーンできるようになります
				これには老人も含まれます
				'''
		}
	}

