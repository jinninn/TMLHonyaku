			}

			UniverseSplitter: {
				DisplayName: 宇宙の通信機
				Tooltip:
					'''
					カーソルにエネルギーフィールドを展開する
					フィールドが展開された後、複数の小さな光線を召喚する
					数秒後、フィールドの位置に巨大なレーザー光線が出現する
					この効果にはクールダウンが存在する
					クールダウン中にアイテムを使用しようとすると、ショートして自分にダメージを与えることになる
					[c/BB57FF:「前時代の古代の遺物で、あなたの命令を待っている]
					[c/BB57FF:　これは恐ろしいアイデアだが、どうせあなたが考えたわけではないし....関係ないだろう？」]
					'''
			}

			VengefulSunStaff: {
				DisplayName: 復讐の太陽の杖
				Tooltip:
					'''
					共に戦う復讐に燃える太陽の精霊を召喚する
					召喚すればするほど力を増す
					'''
			}

			Vigilance: {
				DisplayName: ヴィジランス
				Tooltip: 共に戦うソウルシーカーを召喚する
			}

			VileFeeder: {
				DisplayName: ヴァイルフィーダー
				Tooltip: 共に戦うイーターオブワールドの幼体を召喚する
			}

			ViralSprout: {
				DisplayName: ウイルススプラウト
				Tooltip:
					'''
					共に戦う賢者の霊を召喚する
					「賢者の毒」を敵に付与し、魂が多いほど強力になる
					'''
			}

			VoidConcentrationStaff: {
				DisplayName: 深淵の杖
				Tooltip:
					'''
					ヴォイドオーブを発射して攻撃する不吉なオーラを召喚する
					オーラが発動している間、ミニオンのダメージが5%増加する
					使用するにはミニオンのスロットが3つ必要
					オーラは一度に一つしか出せない
					右クリックで大きくなるブラックホールを展開する
					'''
			}


			WarloksMoonFist: {
				DisplayName: ウォーロックのムーンフィスト
				Tooltip:
					'''
					共に戦う天空の拳を召喚する
					使用するにはミニオンのスロットが4つ必要
					'''
			}

			WitherBlossomsStaff: {
				DisplayName: 朽ちた花の杖
				Tooltip:
					'''
					頭上に4つの枯れた花を召喚する
					4つの花でミニオンのスロットを2つ消費する
					'''
			}

			WulfrumController: {
				DisplayName: ウルフラムコントローラー
				Tooltip:
					'''
					 共に戦うウルフラムのドローンを召喚する
					リモコンを持ちながら右クリックを押し続けると、すべてのドローンがスーパーチャージモードに切り替わる
					スーパーチャージされたドローンは攻撃をやめ、ウルフラムエネルギーでプレイヤーを強化する
					ビームは再生と防御力を増加させる
					マウスカーソルを近づけると、他のプレイヤーを回復させることもできる
					'''
			}

			YharonsKindleStaff: {
				DisplayName: ヤーロンの杖
				Tooltip:
					'''
					灼熱のドラゴンを召喚し、共に戦う
					使用するにはミニオンのスロットが5つ必要
					'''
			}
		}

		Typeless: {
			StratusSphere: {
				DisplayName: 層雲の宝珠
				Tooltip:
					'''
					特異点を放ち、その広範囲に存在するあらゆる存在へ影響を及ぼす
					影響下のプレイヤーは時間経過でスターバーストを獲得し、敵は代わりにダメージを受ける
					<right>でスターバーストを障壁として形成し、体力の代わりにスターバーストを消費して被弾を防ぐことができる
					特異点を展開すると障壁は解除され、障壁を展開すると特異点は解除される
					「魂を星へと変えるなど、愚かしい発想だ」
					'''
			}

			RelicOfDeliverance: {
				DisplayName: 救済の遺物
				Tooltip:
					'''
					<left>を使用すると槍に乗る
					<left>を押し続けると槍を回転させ、速度を低下させる
					離すと高速で自身を発射する。ボスが生存中は速度が半減する
					チャージ中に速度が低下しすぎるとチャージが失敗し、速度がリセットされる
					ダッシュにより敵を貫通し、ブロックを通過できる
					ブロック内に長時間滞在すると入口位置にワープする
					<right> で降りる
					槍を構えている間、全ての召喚物のダメージが大幅に減少する
					[c/FF8C00:「復讐が私を駆り立て、報復以外の考えはなかった]
					[c/FF8C00:　竜は私からすべてを奪い、砕けた私の残骸を地面に散乱させた]
					[c/FF8C00:　しかし、彼女の傍にいた時、戦うに値するものがまだあると悟った」]
					'''
			}

			ClaretCannon: {
				DisplayName: クラレットキャノン
				Tooltip:
					'''
					超高密度のクラレット弾を発射する
					弾は敵に命中すると爆発し、血のオーブを放出する
					爆発は[cbuff:CalamityMod/Laceration]を付与し防御力を大幅に低下させる
					血のオーブを拾うと、可能な場合は[cbuff:PotionSickness]を軽減する
					[cbuff:PotionSickness]がない場合、ライフ自然回復を増進する
					10秒に1回しか発射できない
					'''
			}

			Aestheticus: {
				DisplayName: エステティカス
				Tooltip:
					'''
					爆発して敵を減速させるクリスタルを発射する
					すべてのダメージステータスを一度に低下させる
					'''
			}

			ColdheartIcicle: {
				DisplayName: 冷心のつらら
				Tooltip: "「凍えるほどイケてる」"
			}

			EyeofMagnus: {
				DisplayName: アイ・オブ・マグナス
				Tooltip:
					'''
					敵の防御力を低下させる強力なビームを発射する
					ヒット時にマナとライフを回復する
					すべてのダメージステータスを一度に低下させる
					'''
			}

			LunicEye: {
				DisplayName: ルーニックアイ
				Tooltip:
					'''
					敵の防御力を低下させるルーニックビームを発射する
					すべてのダメージステータスを一度に低下させる
					'''
			}

			Skynamite: {
				DisplayName: スカイナマイト
				Tooltip:
					'''
					重力を無視する浮遊性の爆発物を投げる
					「これを使うのに航空力学の専攻は必要ない...」
					'''
			}

			StarStruckWater: {
				DisplayName: 星の水
				Tooltip: ブロックにアストラルの汚染を広げる
			}
		}
	}
}

