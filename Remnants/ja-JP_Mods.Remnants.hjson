Configs: {
	Worldgen: {
		DisplayName: " ワールド生成"

		Headers: {
			Terrain: 地形
			Structure: 構造物
			LargerSky: 世界のバランス設定（上級）
		}

		OreFrequency: {
			Label: "[i:11] 鉱石の頻度"
			Tooltip: 新しいワールドに生成される鉱石の量を調整します
		}

		TrapFrequency: {
			Label: "[i:539] 罠の頻度"
			Tooltip: 新しいワールドに生成される罠の量を調整します
		}

		CloudDensity: {
			Label: "[i:751] 空の密度"
			Tooltip: 新しいワールドに生成される浮遊島や雲の量を調整します
		}

		ExperimentalWorldgen: {
			Label: "[i:1344] 実験的ワールド生成"
			Tooltip:
				'''
				開発中のワールド生成機能を有効にします

				注意：テスト目的専用 ― 通常のプレイでは使用しないでください
				'''
		}

		Safeguard: {
			Label: "[i:156] セーフガード"
			Tooltip:
				'''
				互換性のないModや設定を使用している場合にワールドの生成を防止します

				注意：強く推奨 ― 無効にする場合は自己責任で
				'''
		}

		SunkenSeaRework: {
			Label: "[i:2625] 沈没海リワーク"
			Tooltip:
				'''
				Calamity Modと併用することで、沈没海のリワークを有効にします

				注意：このバイオームが公式に更新されると無効になります
				'''
		}

		CabinFrequency: {
			Label: "[i:4080] 地下小屋の頻度"
			Tooltip: 新しいワールドに生成される地下小屋の数を調整します
		}

		RailroadFrequency: {
			Label: "[i:2340] 線路の頻度"
			Tooltip: 新しいワールドに生成される線路の数を調整します
		}

		FlatSurfaceRatioIncrease: {
			Label: 地表の高さを低下
			Tooltip:
				'''
				指定されたブロック数だけ地表のしきい値を下げます

				注意：セーフガードが有効な場合は無効になります
				'''
		}

		FlatUndergroundRatioIncrease: {
			Label: 洞窟の高さを低下
			Tooltip:
				'''
				指定されたブロック数だけ洞窟層のしきい値を下げます

				注意：セーフガードが有効な場合は無効になります
				'''
		}

		FlatLavaRatioIncrease: {
			Label: 溶岩層の高さを低下
			Tooltip:
				'''
				指定されたブロック数だけ溶岩層のしきい値を下げます

				注意：セーフガードが有効な場合は無効になります
				'''
		}

		LifeCrystalReduction: {
			Label: "[i:29] ライフクリスタル削減"
			Tooltip: ワールドから削除されるライフクリスタルの割合を制御します
		}

		IceMountainStyle: {
			Label: "[i:664] 山"
			Tooltip: 新しいワールドに生成される氷山の数を制御します
		}

		AquaticDepthsRework: {
			Label: "[i:2338] 深海の洞窟のリワーク"
			Tooltip:
				'''
				Thorium Modと併用することで、深海の洞窟のリワークを有効にします
				これにより、隣接するバイオームへ侵入することも防止されます
				'''
		}

		Prototypes: {
			Label: "[i:Remnants/PrototypePlating] プロト"
			Tooltip:
				'''
				プロト・ライフカプセルの生成を有効化します

				注記: 未完成です！
				'''
		}
	}

