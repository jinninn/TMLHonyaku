			'''
			爆発ダメージが5%増加
			爆発物が爆発時に50%の確率でカオスフレイムを発射する
			'''
	}

	TarragonVisor: {
		SetBonus: 爆発物が爆発時にエネルギーと葉をばら撒くことがある
		DisplayName: タラゴンの重兜
		Tooltip:
			'''
			爆発ダメージが10%増加し、爆発クリティカル率が10%上昇
			被ダメージを10%軽減
			爆発範囲が22%拡大
