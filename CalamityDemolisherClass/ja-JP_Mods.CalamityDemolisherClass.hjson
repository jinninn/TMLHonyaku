	}

	SilvaPlate: {
		SetBonus:
			'''
			爆発ダメージが10%増加
			爆発物が爆発時に時折、自然エネルギーの爆発を起こす
			'''
		DisplayName: シルヴァの重兜
		Tooltip:
			'''
			爆発ダメージが25%増加し、爆発クリティカル率が13%上昇
			爆発範囲が33%拡大
			'''
