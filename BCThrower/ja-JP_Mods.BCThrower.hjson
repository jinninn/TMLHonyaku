CommonTooltips: {
	Stats: {
		# ---------------
		# Basic Stats:
		# ---------------
		PercentIncThrowDmg: "投擲ダメージが{0}%増加"
		PercentIncThrowCrit: "投擲クリティカル率が{0}%上昇"
		PercentIncThrowSpd: "投擲攻撃速度が{0}%上昇"
		PercentIncThrowVelocity: "投擲武器の弾速が{0}%上昇"
		PercentIncThrowKB: "投擲ノックバックが{0}%増加"
		PercentThrowConserv: "{0}%の確率で投擲武器を消費しない"
		PercentDamageReduction: 被ダメージを{0}%軽減
		# ---------------
		# Compound Stats:
		# ---------------
		PercentIncThrowDmgAndCrit: "投擲ダメージが{0}%増加し、投擲クリティカル率が{0}%上昇"
		PercentIncThrowDmgAndSpd: "投擲ダメージが{0}%増加し、投擲攻撃速度が{0}%上昇"
		PercentIncThrowCritAndSpd: "投擲クリティカル率と投擲攻撃速度が{0}%上昇"
		PercentIncThrowVelAndDmg: "投擲ダメージが{0}%増加し、投擲武器の弾速が{0}%上昇"
		PercentIncThrowVelAndCrit: "投擲武器の弾速と投擲クリティカル率が{0}%上昇"
		PercentIncThrowVelAndSpd: "投擲攻撃速度と弾速が{0}%上昇"
		PercentIncThrowVelAndKB: "投擲武器の弾速が{0}%上昇し、投擲ノックバックが{0}%増加"
		PercentIncThrowAndMoveSpd: "移動速度と投擲攻撃速度が{0}%上昇"
		PercentIncThrowVelAndMoveSpd: "移動速度と投擲武器の弾速が{0}%上昇"
		PercentIncThrowDmgAndMoveSpd: "投擲ダメージが{0}%増加し、移動速度が{0}%上昇"
		# ---------------
		# Aggro:
		# ---------------
		# 200 or less Aggro Reduction
		SlightReducedAggro: 敵に少し狙われにくくなる
		# 201 to 399 Aggro Reduction
		ReducedAggro: 敵に狙われにくくなる
		# 400 or more Aggro Reduction
		GreatReducedAggro: 敵にかなり狙われにくくなる
		# ---------------
		# Regen:
		# ---------------
		# +1 Regen
		SlightRegen: ライフ自然回復を少し増進
		# +2 to +4 Regen
		Regen: ライフ自然回復を増進
		# +5 to +7 Regen
		GreatRegen: ライフ自然回復を大きく増進
		# +8 or more Regen
		HugeRegen: ライフ自然回復をとても大きく増進
		# ---------------
		# Converted armor:
		# ---------------
		FossilCrit: 遠距離と投擲ダメージが5%増加
		FossilDmg: 遠距離と投擲クリティカル率が4%上昇
		CrystalNinjaConserv:
			'''
			10%の確率で弾薬を消費しない
			10%の確率で投擲武器を消費しない
			'''
		ShinobiHead:
			'''
			召喚できるセントリーの数が2体増え、召喚ダメージが20%増加
			投擲ダメージが15%増加
			'''
		ShinobiBody:
			'''
			召喚ダメージが20%増加
			投擲ダメージが15%増加
			'''
		ShinobiLegs:
			'''
			召喚ダメージが20%増加
			投擲クリティカル率が15%上昇
			'''
		MonkHead: 投擲攻撃速度が15%上昇し、召喚できるセトンリーの数が1体増える
		MonkBody:
			'''
			召喚ダメージが20%増加
			投擲ダメージが15%増加
			'''
		MonkLegs: 投擲クリティカル率が12%上昇し、移動速度が20%上昇
	}

	SetBonus: {
		FossilBCThrower:
			'''
			20%の確率で弾薬を消費しない
			20%の確率で投擲武器を消費しない
			'''
		NinjaBCThrower:
			'''
			移動速度が12%上昇
			投擲武器の弾速が12%上昇
			'''
		CrystalNinjaBCThrower:
			'''
			横方向入力2回で高速ステップ
			投擲ダメージが5%増加し、クリティカル率が5%上昇
			'''
		Stealth:
			'''
			{$CommonTooltips.Stats.SlightRegen}
			{$CommonTooltips.Stats.SlightReducedAggro}
			'''
		Feather:
			'''
			ジャンプ速度と落下耐性が増加
			攻撃を受けると、羽根を発射して反撃する
			'''
		Master:
			'''
			投擲武器の弾速が10%上昇
			攻撃を回避することがある
			'''
		Akuma:
			'''
			投擲攻撃で混乱、炎上を敵に与えることがある
			投擲攻撃時に敵を混乱させ、炎上させる火炎瓶を投げることがある
			'''
		Hidden:
			'''
			投擲クリティカル率が10%上昇
			投擲武器を選択中、移動しないとステルスが蓄積される
			ステルス状態になると、次の投擲攻撃のダメージが増加し、敵に狙われにくくなる
			ステルスは移動しても失われないが、移動速度が低下する
			投擲武器を選択中でない場合は、時間の経過とともにステルスが減少する
			'''
		DarkSet:
			'''
			20%の確率で投擲武器を消費しない
			敵に少し狙われにくくなる
			{0}を二度押しで、カーソルの位置にテレポートし、投擲武器が一時的に強化される
			この効果は15秒のクールダウンがある
			'''
		DarkTriggerUp: 上
		DarkTriggerDown: 下
		Winter:
			'''
			15%の確率で投擲武器を消費しない
			敵に少し狙われにくくなる
			25%の確率で投擲武器が3つに増える
			'''
		Bionic:
			'''
			敵に狙われにくくなる
			敵を倒すと、与えたダメージの一部、ライフを回復し、投擲武器を一時的に強化する
			この効果は6秒のクールダウンがある
			'''
		Void:
			'''
			33%の確率で投擲武器を消費しない
			攻撃を受けたとき、攻撃を吸収することがある
			吸収した場合は、ダメージを受けず、受けるはずだったダメージの一部、ライフを回復し、
			敵を切り裂く渦を発生させる
			ライフが少ないか、効果が連続して発動しなかった場合、確率が上昇する
			'''
	}

	Config: {
		DamageChange: この武器のダメージクラスを投擲武器に変更します
		MagicTweaks: さらにマナの消費が少なくなりますが、ダメージが減少します
		DamageRebalance: この武器のダメージも他の投擲武器と一致するように調整されます
		ArmorChange: この防具セットのステータス/ボーナスを投擲武器向けに変更します
		ConvertWarning: 元々のダメージタイプにより、この武器は汎用（つまりクラス固有でない）の接頭辞のみが付きます
	}

	Shop: {
		NinjaArmorCond: その他のバニラの調整で「忍者セットの入手方法を変更する」をオンにする
		MasterScrollCond: ゴーレム、エンプレスオブライト、またはデュークフィシュロンのいずれかを倒した後、夜間に
		DisciplineScrollCond: キングスライム以外のハードモード前のボスを倒した後、昼間に
		ShadowspikeBallCond: ゴブリンウォーロックを倒した後
	}

	Flasks: {
		FlaskBase: "近接攻撃、投擲攻撃、鞭の攻撃に"
		FlaskFire: 炎上の追加効果を付与
		FlaskPoison: 毒の追加効果を付与
		FlaskCursed: 呪炎の追加効果を付与
		FlaskGold: ドロップ金額増加の追加効果を付与
		FlaskIchor: 敵の防御減少の追加効果を付与
		FlaskParty: 紙吹雪の追加攻撃を付与
		FlaskNanites: 混乱の追加効果を付与
		FlaskVenom: 酸性毒の追加効果を付与
	}
}

