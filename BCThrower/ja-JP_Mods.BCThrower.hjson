Configs: {
	ConversionConfig: {
		DisplayName: バニラの変換

		assassinArmorConv: {
			Label: "[i:4982] 水晶の暗殺者のセットボーナスを変更"
			Tooltip:
				'''
				{$CommonTooltips.Config.ArmorChange}
				防御力も少し増加し、セットボーナスのダッシュは変更されません
				'''
		}

		shinboiArmorConv: {
			Label: "[i:3880] 忍び装束のセットボーナスを変更"
			Tooltip:
				'''
				{$CommonTooltips.Config.ArmorChange}
				召喚ダメージの増加は維持されますが、近接攻撃速度の上昇はなくなります
				セットボーナスと防御力は変更されません
				'''
		}

		ninjaArmorConv: {
			Label: "[i:256] 忍者のセットボーナスを変更"
			Tooltip:
				'''
				{$CommonTooltips.Config.ArmorChange}
				防御力は変更されません
				新しいステータスは、1.4以前の忍者セットと同じではありません
				'''
		}

		biomeWepConv: {
			Label: "[i:1571] バイオーム武器のダメージクラスを変更"
			Tooltip:
				'''
				スカージオブコラプターとヴァンパイアナイフのダメージクラスを投擲武器に変更します
				投擲武器に変更すると、スカージオブコラプターのダメージステータスも他の投擲武器と同等になるように調整されます
				一度に変更できる武器は1つだけで、各クラスにそれぞれ専用のバイオームの宝箱武器が用意されています
				この設定をオンにすると、スコージオブコラプターとヴァンパイアナイフのダメージクラスを変更できます
				なお、元のダメージタイプが原因で、どちらの武器も変更後は汎用的な（つまりクラス固有でない）接頭辞しか付きません
				'''
		}

		shadowflameKnifeConv: {
			Label: "[i:3054] シャドウフレイムナイフのダメージクラスを変更"
			Tooltip:
				'''
				{$CommonTooltips.Config.DamageChange}
				{$CommonTooltips.Config.ConvertWarning}
				{$CommonTooltips.Config.DamageRebalance}
				'''
		}

		flyingKnifeConv: {
			Label: "[i:3030] フライングナイフのダメージクラスを変更"
			Tooltip:
				'''
				{$CommonTooltips.Config.DamageChange}
				{$CommonTooltips.Config.ConvertWarning}
				'''
		}

		flaskConv: {
			Label: "[i:3105] 毒性のフラスコのダメージクラスを変更"
			Tooltip:
				'''
				{$CommonTooltips.Config.DamageChange}
				{$CommonTooltips.Config.ConvertWarning}
				{$CommonTooltips.Config.MagicTweaks}
				'''
		}

		magicDaggerConv: {
			Label: "[i:517] マジックダガーのダメージクラスを変更"
			Tooltip:
				'''
				{$CommonTooltips.Config.DamageChange}
				{$CommonTooltips.Config.ConvertWarning}
				{$CommonTooltips.Config.MagicTweaks}
				'''
		}

		thrownWaterConv: {
			Label: "[i:422] 投げる水にダメージクラスを追加"
			Tooltip:
				'''
				バニラの投擲水武器に投擲武器のダメージクラスを与えます
				これは聖水、不浄の水、血色水に影響します
				これらの武器には通常はダメージクラスは設定されていません
				'''
		}

		airplaneConv: {
			Label: "[i:4343] 紙飛行機のダメージクラスを変更"
			Tooltip: バニラ紙飛行機のダメージクラスを投擲に変更します
		}

		thorwingKnifeConv: {
			Label: "[i:279] 投げナイフのダメージクラスを変更"
			Tooltip: 投げナイフと毒ナイフのダメージクラスを投擲武器に変更します
		}

		grenadeConv: {
			Label: "[i:168] グレネードのダメージクラスを変更"
			Tooltip:
				'''
				全てのバニラのグレネードのダメージクラスを投擲武器に変更します
				この変更は、グレネード（粘着グレネード/弾むグレネードを含む）、手蜂弾、ハッピーグレネードに影響します
				その他の爆発物（爆弾、ダイナマイトなど）は影響を受けず、クラス指定はありません
				'''
		}

		shurikenConv: {
			Label: "[i:42] 手裏剣のダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		starAniseConv: {
			Label: "[i:1913] スターアニスのダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		boneJavConv: {
			Label: "[i:3378] 骨のジャベリンのダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		boneKnifeConv: {
			Label: "[i:3379] 骨の投げナイフのダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		aleThrowerConv: {
			Label: "[i:3821] エールトサーのダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		molotovConv: {
			Label: "[i:2590] 火炎瓶のダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		boneConv: {
			Label: "[i:154] 骨のダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		spikyBallConv: {
			Label: "[i:161] スパイクボールのダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		snowballConv: {
			Label: "[i:949] 雪玉のダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		rottenEggConv: {
			Label: "[i:1809] 腐った卵のダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		javelinConv: {
			Label: "[i:3094] ジャベリンのダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		daggerfishConv: {
			Label: "[i:3197] 凍ったダガーフィッシュのダメージクラスを変更"
			Tooltip: "{$CommonTooltips.Config.DamageChange}"
		}

		globalConversion: {
			Label: 全ての消費する遠距離武器を変更
			Tooltip:
				'''
				全ての消費する遠距離武器（バニラとMod）を自動的に投擲武器に変更します
				バニラの雪玉のように弾薬としてもカウントされるアイテムは変換されません
				武器種別の変更に伴うステータス調整は行われないため、バランス調整に影響する可能性があります
				この設定は、以下の多くの個別変更設定を上書きします
				'''
		}

		monkArmorConv: {
			Label: "[i:3806] モンクセットのボーナスを変更"
			Tooltip:
				'''
				{$CommonTooltips.Config.ArmorChange}
				召喚ダメージ増加は維持されますが、近接攻撃速度（鞭に利益をもたらす）の上昇はなくなります
				セットボーナスと防御値は変更されません
				'''
		}
	}

	TweaksConfig: {
		DisplayName: その他のバニラの調整

		visiblyFreeNinja: {
			Label: 自由になった忍者
			Tooltip:
				'''
				キングスライムの描画を微調整し、忍者を解放した後、体内に閉じ込められた忍者を消します
				忍者が解放されていないワールドでは効果がありません
				他のModでキングスライムの描画が変更されている場合は、奇妙な（視覚的な）効果が生じる可能性があることに注意してください
				'''
		}

		moveNinjaArmor: {
			Label: 忍者セットの入手方法を変更する
			Tooltip:
				'''
				忍者セットをキングスライムから入手できなくなる代わりに、忍者から買えるようにします
				また、売却価格を1つ15シルバーに微調整します
				参考までに、フードは通常20シルバー、シャツとパンツは10シルバーです
				'''
		}

		moveShurikens: {
			Label: 商人から手裏剣を買えなくする
			Tooltip: 忍者NPCから手裏剣を買えるようになりますが、商人NPCから手裏剣を買えなくなります
		}

		moveThrowingKnives: {
			Label: 商人から投げナイフを買えなくする
			Tooltip:
				'''
				忍者から投げナイフを買えるようになりますが、商人から投げナイフを買えなくなります
				忍者は、商人と違い、ブラッドムーンのときだけでなく、常に投げナイフを買えることに注意してください
				'''
		}

		flasksAffectThrowingWeapons: {
			Label: フラスコは投擲武器にも影響を与える
			Tooltip:
				'''
				バニラのフラスコの効果を投擲ダメージのある武器にも影響するようにします
				また、アイテムのツールチップも変更に合わせて調整します（ただし、バフツールチップは変更されません）
				Modで追加されるフラスコには影響しません
				'''
		}

		safeNinja: {
			Label: スライムまみれの忍者の死亡セーフティ
			Tooltip:
				'''
				スライムまみれの忍者（通常の忍者NPCではありません）が、ブルースライムとスパイクスライムから受けるダメージが25%になります
				キングスライムから出てくるスライムによって忍者が死亡するのを防ぎます
				'''
		}
	}
}
