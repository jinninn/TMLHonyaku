	LunaticLanceDebuff: {
		DisplayName: ヴォイドインペイル
		Description: 敵はヴォイドの力を受けたジャベリンが刺さっている
	}

	Dirty: {
		DisplayName: 汚れている
		Description: 被ダメージが増加する。汚れているからだ。
	}

	CryoChill: {
		DisplayName: 凍え
		Description: 敵の移動速度が低下
	}

	StickyWeb: {
		DisplayName: ねばつく糸
		Description: 敵の動きを麻痺させる
	}

	BloodyHarpoonDebuff: {
		DisplayName: ブラッディエストキャッチ
		Description: 敵は血の銛に引っ張られている
	}

	TwinnailDebuff: {
		DisplayName: ツインネイル
		Description: 敵は釘が刺さっている
	}
}

